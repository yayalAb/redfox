<odoo>
    <record model="ir.ui.view" id="fleet_vehicle_form_view">
        <field name="name">fleet.vehicle.form (in fleet_vehicle_fuel_capacity)</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form" />
        <field name="arch" type="xml">
            <field name="color" position="after">
                <field name="fuel_capacity" />
            </field>
        </field>
    </record>
    <record id="fleet_vehicle_log_contract_view_form_inherit" model="ir.ui.view">
    <field name="name">fleet.vehicle.log.contract.form.inherit</field>
    <field name="model">fleet.vehicle.log.contract</field>
    <field name="inherit_id" ref="fleet.fleet_vehicle_log_contract_view_form"/>
    <field name="arch" type="xml">
        <!-- Find the field and force required to be false -->
        <xpath expr="//field[@name='vehicle_id']" position="attributes">
            <attribute name="required">0</attribute>
        </xpath>
    </field>
</record>
</odoo>
