    <record id="action_employee_evaluation_python" model="ir.actions.server">
    <field name="name">Employee Evaluations (Python)</field>
    <field name="model_id" ref="hr.model_hr_employee"/>
    <field name="state">code</field>
    <field name="code">
            action = env['hr.employee'].action_open_employee_evaluations()
        </field>
    </record>

    <menuitem
        id="hr_performance_employee_menu"
        name="Employees to Evaluate"
        parent="hr_performance_360_menu"
        action="action_employee_evaluation_python"
        sequence="6"
    />

      <menuitem
        id="hr_performance_employee_self_service_menu"
        name="Employees to Evaluate"
        parent="hr_employee_self_service.main_menu_self_service_probc"
        action="action_employee_evaluation_python"
        sequence="6"
    />
