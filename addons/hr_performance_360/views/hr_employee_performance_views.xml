<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_performance_employee_list_view" model="ir.ui.view">
        <field name="name">hr.employee.performance.list</field>
        <field name="model">hr.employee</field>
        <field name="arch" type="xml">
            <list string="Evaluatable Employees"
                  decoration-success="is_evaluated == True"
                  decoration-info="is_evaluated == False">
                <field name="name"/>
                <field name="work_phone" string="Phone"/>
                <!-- <field name="department_id"/> -->
                <field name="job_id"/>
                <field name="evaluation_template_id"/>
                <field name="evaluation_type" widget="badge"
                       decoration-info="evaluation_type == 'self'"
                       decoration-success="evaluation_type == 'peer'"
                       decoration-warning="evaluation_type == 'subordinate'"
                       decoration-danger="evaluation_type == 'supervisor'"/>
                <field name="is_evaluated" column_invisible="1"/>
                <button
                    name="action_open_performance_evaluation"
                    type="object"
                    string="Evaluate"
                    class="oe_highlight"
                    invisible="is_evaluated"
                />
            </list>
        </field>
    </record>

