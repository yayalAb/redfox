# Odoo 18 Docker Deployment - Environment Variables
# Copy this file to .env and adjust values for your environment

# PostgreSQL
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo18@2021
POSTGRES_DB=postgres

# Odoo (must match PostgreSQL credentials)
HOST=db
USER=odoo
PASSWORD=odoo18@2021

# Optional: Odoo configuration
# ODOO_EXTRA_ADDONS=/mnt/extra-addons
# ODOO_CONFIG=/etc/odoo/odoo.conf
