# Odoo 18 Docker Deployment - Environment Variables

# PostgreSQL
POSTGRES_USER=odoo
POSTGRES_PASSWORD=odoo18@2021
POSTGRES_DB=postgres

# Odoo (must match PostgreSQL credentials)
HOST=db
USER=odoo
PASSWORD=odoo18@2021

# Odoo database manager master password (required for /web/database/manager)
ADMIN_PASSWD=odooepr@loyal
