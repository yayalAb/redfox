<odoo>
    <record id="view_mrp_production_design_form" model="ir.ui.view">
        <field name="name">mrp.production.design.form</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//group/group[1]" position="inside">
                <field name="lv_design" invisible="is_nested" options="{'no_create': True, 'no_create_edit': True}"/>
                <field name="hv_design" invisible="is_nested" options="{'no_create': True, 'no_create_edit': True}"/>
                 <field name="production_type" invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>