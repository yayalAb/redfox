<odoo>
    <record id="view_service_request_reject_wizard_form" model="ir.ui.view">
        <field name="name">service.request.reject.wizard.form</field>
        <field name="model">service.request.reject.wizard</field>
        <field name="arch" type="xml">
            <form string="Reject Requisition">
                <group>
                    <field name="service_request" readonly="1" />
                    <field name="rejection_reason"
                        placeholder="Please provide the reason for rejecting this service request..." />
                </group>
                <footer>
                    <button name="action_confirm_reject" string="Confirm Rejection" type="object"
                        class="oe_highlight" />
                    <button string="Cancel" class="btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_service_request_reject_wizard" model="ir.actions.act_window">
        <field name="name">Reject Service Request</field>
        <field name="res_model">service.request.reject.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_service_request': active_id}</field>
    </record>


