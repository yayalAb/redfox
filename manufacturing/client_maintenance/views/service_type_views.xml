<odoo>
    <record id="view_service_type_list" model="ir.ui.view">
        <field name="name">service.type.list.view</field>
        <field name="model">service.type</field>
        <field name="arch" type="xml">
            <list editable="top">
                <field name="name" />
            </list>
        </field>
    </record>

    <record id="action_service_type" model="ir.actions.act_window">
        <field name="name">Service Types</field>
        <field name="res_model">service.type</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_service_type"
        name="Service Types"
        parent="mrp.menu_mrp_configuration"
        action="action_service_type"
        sequence="15" />
</odoo>