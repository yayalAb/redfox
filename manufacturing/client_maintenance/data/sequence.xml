<odoo>
    <record id="sequence_service_request" model="ir.sequence">
        <field name="name">Service Request Sequence</field>
        <field name="code">service.request</field>
        <field name="prefix">SR-</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False" />
    </record>

    <record id="sequence_manufacturing_order" model="ir.sequence">
        <field name="name">Manufacturing Order</field>
        <field name="code">manufacturing.order</field>
        <field name="prefix">MO-</field>
        <field name="suffix">-%(y)s</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False" />
    </record>

    <record id="sequence_client_maintenance" model="ir.sequence">
        <field name="name">Client Maintenance</field>
        <field name="code">client.maintenance</field>
        <field name="prefix">CM-</field>
        <field name="suffix">-%(y)s</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False" />
    </record>

    <record id="sequence_client_test" model="ir.sequence">
        <field name="name">Client Test</field>
        <field name="code">client.test</field>
        <field name="prefix">CT-</field>
        <field name="suffix">-%(y)s</field>
        <field name="padding">4</field>
        <field name="company_id" eval="False" />
    </record>
</odoo>