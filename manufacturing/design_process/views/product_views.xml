<odoo>
    <record id="view_product_template_design_form" model="ir.ui.view">
        <field name="name">product.template.design.form</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="lv_design" invisible="1" />
                <field name="hv_design" invisible="1" />
                <button name="action_view_lv_design" string="LV Designs"
                    type="object" icon="fa-tachometer" />

                <button name="action_view_hv_design" string="HV Designs"
                    type="object" icon="fa-tachometer" />
            </xpath>
        </field>
    </record>
</odoo>