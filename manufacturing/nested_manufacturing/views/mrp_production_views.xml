<odoo>
    <record id="mrp_production_form_view_inherit_nested_mo" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.nested.mo</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view" />
        <field name="arch" type="xml">
            <div name="button_box" position="inside">
                <button name="action_open_nested_mo"
                    type="object"
                    string="Workorders"
                    class="oe_stat_button"
                    icon="fa-check-square-o"
                    invisible="state == 'draft' or not is_main">
                </button>
            </div>

            <xpath expr="//page[@name='operations']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>

    <record id="action_client_maintenance" model="ir.actions.act_window">
        <field name="name">Client Maintenance</field>
        <field name="res_model">mrp.production</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('production_type', '=', 'maintenance')]</field>
        <field name="context">{'default_production_type': 'maintenance'}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new Payment request.
            </p>
            <p>
                Use this menu to create payment requests.
            </p>
        </field>
    </record>

    <record id="action_client_testing" model="ir.actions.act_window">
        <field name="name">Client Testing</field>
        <field name="res_model">mrp.production</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('production_type', '=', 'test')]</field>
        <field name="context">{'default_production_type': 'test'}</field>
        <field name="help" type="html">
            <p class="oe_view_nocontent_create">
                Click to create a new Payment request.
            </p>
            <p>
                Use this menu to create payment requests.
            </p>
        </field>
    </record>

    <odoo>
        <record id="mrp.mrp_production_action" model="ir.actions.act_window">
            <field name="context">{'default_production_type': 'manufacturing'}</field>
        </record>
    </odoo>

    <menuitem id="menu_client_maintenance" name="Client Maintenance"
        parent="mrp.menu_mrp_manufacturing"
        action="action_client_maintenance" sequence='2' />

    <menuitem id="menu_client_testing" name="Client Testing" parent="mrp.menu_mrp_manufacturing"
        action="action_client_testing" sequence='3' />
</odoo>