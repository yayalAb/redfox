<odoo>
    <record id="view_mrp_routing_workcenter_inherited_list" model="ir.ui.view">
        <field name="name">mrp.routing.workcenter.product.list</field>
        <field name="model">mrp.routing.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_routing_workcenter_tree_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='time_cycle']" position="after">
                <field name="product_id" />
                <field name="workorder_type_id" />
            </xpath>
        </field>
    </record>

    <record id="view_mrp_routing_workcenter_inherited_form" model="ir.ui.view">
        <field name="name">mrp.routing.workcenter.product.form</field>
        <field name="model">mrp.routing.workcenter</field>
        <field name="inherit_id" ref="mrp.mrp_routing_workcenter_form_view" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='workcenter_id']" position="after">
                <field name="product_id" />
                <field name="workorder_type_id" />
            </xpath>
        </field>
    </record>
</odoo>