<!-- custom_quality_fat_plan/report/fat_report.xml -->
<odoo>
    <record id="fat_report_paperformat" model="report.paperformat">
        <field name="name">FAT Report Format</field>
        <field name="default" eval="False" />  <!-- Avoid setting to True unless you want it global -->
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">0</field>
        <field name="margin_bottom">10</field>  <!-- Adjust bottom as needed -->
        <field name="margin_left">10</field>
        <field name="margin_right">10</field>
        <field name="header_line" eval="False" />
        <field name="header_spacing">0</field>
        <field name="dpi">90</field>
    </record>

    <record id="action_report_fat" model="ir.actions.report">
        <field name="name">FAT Report</field>
        <field name="model">mrp.production</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">custom_manufacturing.report_fat_template</field>
        <field name="report_file">custom_manufacturing.report_fat_template</field>
        <field name="print_report_name">'FAT Report - %s' % (object.name)</field>
        <field name="paperformat_id" ref="custom_manufacturing.fat_report_paperformat" />
        <field name="binding_model_id" ref="mrp.model_mrp_production" />
        <field name="binding_type">report</field>
    </record>

</odoo>