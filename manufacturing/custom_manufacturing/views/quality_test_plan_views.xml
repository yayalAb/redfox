<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Form View for Quality Test Plan -->
    <record id="view_quality_test_plan_form" model="ir.ui.view">
        <field name="name">quality.test.plan.form</field>
        <field name="model">quality.test.plan</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Transformer FAT Plan"/></h1>
                    </div>
                    <group>
                        <field name="product_ids" widget="many2many_tags"/>
                        <field name="picking_type_ids" widget="many2many_tags"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Test Steps" name="plan_lines">
                            <field name="plan_line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name"/>
                                    <field name="test_type"/>
                                    <field name="team_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- list View for Quality Test Plan -->
    <record id="view_quality_test_plan_list" model="ir.ui.view">
        <field name="name">quality.test.plan.list</field>
        <field name="model">quality.test.plan</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Action for Quality Test Plan -->
    <record id="action_quality_test_plan" model="ir.actions.act_window">
        <field name="name">Quality Test Plans</field>
        <field name="res_model">quality.test.plan</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_quality_test_plan"
              name="Quality Test Plans"
              parent="custom_quality_control.menu_quality_configuration"
              action="action_quality_test_plan"
              sequence="100"/>
</odoo>