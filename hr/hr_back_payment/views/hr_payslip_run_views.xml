<odoo>
    <record id="hr_payslip_run_form_inherit_back_payment" model="ir.ui.view">
        <field name="name">hr.payslip.run.form.inherit.back.payment</field>
        <field name="model">hr.payslip.run</field>
        <field name="inherit_id" ref="hr_payroll.hr_payslip_run_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_validate']" position="before">
                 <button name="action_generate_back_payments" string="Generate Back-Payments" type="object" class="btn-secondary" invisible="state != 'draft'"/>
            </xpath>
        </field>
    </record>
</odoo>