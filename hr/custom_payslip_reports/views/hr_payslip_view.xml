<!-- custom_payslip_reports/views/hr_payslip_view.xml -->
<odoo>
    <data>
        <record id="view_hr_payslip_tree_inherit_custom" model="ir.ui.view">
            <field name="name">hr.payslip.tree.inherit.custom</field>
            <field name="model">hr.payslip</field>
            <field name="inherit_id" ref="hr_payroll.view_hr_payslip_tree"/>
            <field name="arch" type="xml">
                <xpath expr="//header" position="inside">
                    <button name="action_open_payslip_report_wizard"
                            type="object"
                            string="Payslip Reports"
                            class="oe_highlight"
                    />
                </xpath>
            </field>
        </record>
    </data>
</odoo>