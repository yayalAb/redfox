<!-- custom_payslip_reports/views/social_contribution_wizard_view.xml -->
<odoo>
    <data>
        <record id="view_social_contribution_wizard_form" model="ir.ui.view">
            <field name="name">social.contribution.wizard.form</field>
            <field name="model">social.contribution.wizard</field>
            <field name="arch" type="xml">
                <form>
                    <group>
                        <field name="branch_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="payslip_ids" invisible="1"/>
                    </group>
                    <footer>
                        <button name="print_report" string="Print" type="object" class="btn-primary"/>
                        <button string="Cancel" class="btn-secondary" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>
    </data>
</odoo>