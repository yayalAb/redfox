<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Paper format for the landscape payroll sheet -->
        <record id="paperformat_payroll_sheet_landscape" model="report.paperformat">
            <field name="name">Payroll Sheet Landscape</field>
            <field name="default" eval="True" />
            <field name="format">A4</field>
            <field name="orientation">Landscape</field>
            <field name="margin_top">5</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">3</field>
            <field name="margin_right">7</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">3</field>
            <field name="dpi">90</field>
        </record>
        <record id="paperformat_payroll_portrait" model="report.paperformat">
            <field name="name">Payroll Portrait</field>
            <field name="format">A4</field>
            <field name="orientation">Portrait</field>
            <field name="margin_top">10</field>
            <field name="margin_bottom">10</field>
            <field name="margin_left">7</field>
            <field name="margin_right">7</field>
            <field name="header_line" eval="False" />
            <field name="header_spacing">3</field>
            <field name="dpi">90</field>
        </record>
    </data>
</odoo>