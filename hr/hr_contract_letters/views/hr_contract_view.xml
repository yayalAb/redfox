<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="hr_contract_letters_view_form" model="ir.ui.view">
        <field name="name">hr.contract.letters.view.form</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form" />
        <field name="arch" type="xml">
            <!-- Add Send/Print Contract button in header -->
            <xpath expr="//header" position="inside">
                 <button name="action_set_to_reviewed" type="object" string="Review"
                    groups="hr_contract_letters.hr_latters_group_reviewer"
                    class="btn-primary" invisible="approval_status != 'draft' or state != 'open'"/>
                <button name="action_set_to_approved" type="object" string="Approve"
                    groups="hr_contract_letters.hr_latters_group_approve"
                    class="btn-success" invisible="approval_status != 'reviewed' or state != 'open'"/>
                <button name="hr_contract_letters.action_hr_contract_send_wizard" 
                        string="Send/Print" 
                        type="action" 
                        class="oe_highlight"
                        icon="fa-envelope"
                        invisible="approval_status != 'approved' or state != 'open'"
                        groups="hr_contract_letters.hr_print_send_group_approve"/>
            </xpath>
            

              <xpath expr="//div[@id='resource_calendar_warning']" position="after" >
                <field name="approval_status"  readonly="1"/>
                <field name="reviewed_by_id"  readonly="1"/>
                <field name="approved_by_id"  readonly="1"/>
            </xpath>
        </field>
    </record>


        <record id="hr_contract_salary_view_form" model="ir.ui.view">
        <field name="name">hr.contract.salary.view.form</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract_salary.hr_contract_view_form" />
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_generate_offer']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            </field>
            </record>


    


</odoo>
