<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Add Print/Send button to training.requisition form view -->
    <record id="hr_training_requisition_view_form_letters" model="ir.ui.view">
        <field name="name">training.requisition.form.letters</field>
        <field name="model">training.requisition</field>
        <field name="inherit_id" ref="training_requisition.training_requisition_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_print_send_training_invitation" 
                        string="Print/Send" 
                        type="object" 
                        class="btn-primary"
                        icon="fa-envelope"/>
            </xpath>
        </field>
    </record>
</odoo>
