<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Training Invitation Letter Report Action -->
    <record id="action_report_training_invitation" model="ir.actions.report">
        <field name="name">Print Training Invitation Letter</field>
        <field name="model">training.requisition</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_contract_letters.report_training_invitation_document</field>
        <field name="report_file">hr_contract_letters.report_training_invitation_document</field>
        <field name="print_report_name">'Training Invitation - %s' % (object.program_name or 'Training Invitation')</field>
        <field name="binding_model_id" eval="False"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Training Invitation Letter Report Template -->
    <template id="report_training_invitation_document">
        <t t-call="web.html_container">
            <t t-call="web.external_layout">
                <t t-foreach="docs" t-as="training">
                    <!-- Iterate over participants to generate one letter per participant; fallback to one letter if no participants -->
                    <t t-set="participants_list" t-value="training.training_participants if training.training_participants else [None]"/>
                    <t t-foreach="participants_list" t-as="participant">
                        <!-- Get employee from participant (participant.lines has employee_id field) -->
                        <t t-set="employee" t-value="participant.employee_id if participant and participant.employee_id else None"/>
                        <div class="page" t-att-style="'font-family: Times New Roman, serif; font-size: 12pt; line-height: 1.6; padding: 20px; background: white; color: black;' + ('page-break-before: always;' if (training_index or participant_index) else '')">
                              <div class="oe_structure" />

                                <t t-set="doc_title" t-value="'Training Invitation Letter'" />
                                <t t-set="doc_number" t-value="'OF/WW/HRGS/030'" />
                                <t t-set="issue_number" t-value="'1'" />
                            <!-- Reference Number and Date -->
                            <div style="text-align: right; margin-bottom: 20px;">
                                <p><strong>Ref No :- <t t-esc="get_ref_no(training) if get_ref_no else ('WG/' + str(training.id).zfill(4) + '/2018' if training.id else 'WG/0000/2018')"/></strong></p>
                                <p><strong>Date :- <t t-esc="current_date_formatted or (current_date.strftime('%B %d, %Y') if current_date and hasattr(current_date, 'strftime') else (str(current_date) if current_date else ''))"/></strong></p>
                            </div>
                            
                            <!-- To Section -->
                            <div style="margin-bottom: 15px;">
                                <p><strong>To: <t t-if="employee and employee.gender == 'male'">Mr. </t><t t-if="employee and employee.gender == 'female'">Mrs. </t><span t-if="employee" t-field="employee.name"/><t t-else="">Participant</t></strong></p>
                                <p t-if="employee and employee.private_city">
                                    <u><b><span t-field="employee.private_city"/></b></u>
                                </p>
                                <p t-elif="employee and employee.address_id and employee.address_id.city">
                                    <u><b><span t-field="employee.address_id.city"/></b></u>
                                </p>
                                <p t-else=""><u><b>Addis Ababa</b></u></p>
                            </div>
                            
                            <!-- Subject -->
                            <div style="margin-bottom: 20px; text-align: center;">
                                <p style="white-space: nowrap; display: inline-block;"><strong>Subject: <u>Invitation for Attending a Training Program</u></strong></p>
                            </div>
                            
                            <!-- Letter Body -->
                            <div style="text-align: justify;">
                                <p>Dear <span t-esc="(employee.name.split()[0] if employee and employee.name and employee.name.strip() else 'Participant')"/>,</p>
                                
                                <p>Based on the training need submitted by your department, a training program entitled <strong>
                                    <span t-if="training.program_name">
                                        <span t-esc="training.program_name or ''"/>
                                    </span>
                                    <t t-else="">________________</t>
                                </strong> has been scheduled to be conducted from <strong>
                                    <t t-if="training.start_date">
                                        <span t-esc="format_datetime_user_tz(training, training.start_date) if format_datetime_user_tz else training.start_date.strftime('%B %d, %Y at %I:%M %p')"/>
                                    </t>
                                    <t t-else="">________________</t>
                                </strong> to <strong>
                                    <t t-if="training.end_date">
                                        <span t-esc="format_datetime_user_tz(training, training.end_date) if format_datetime_user_tz else training.end_date.strftime('%B %d, %Y at %I:%M %p')"/>
                                    </t>
                                    <t t-else="">________________</t>
                                </strong> at <strong>
                                    <span t-if="training.training_place">
                                        <span t-esc="training.training_place or '________________'"/>
                                    </span>
                                    <t t-else="">________________</t>
                                </strong>.</p>
                                
                                <div t-if="training.remark">
                                    <t t-raw="training.remark"/>
                                </div>
                                <!-- <p t-else="">The objective of this program is to enhance participants' knowledge and skills relevant to the subject matter. Accordingly, participants are expected to demonstrate measurable improvement in their work performance following the completion of the training. Your participation is therefore considered essential, and you are requested to attend the session punctually and engage fully throughout the program.</p> -->
                                
                                <p>Should you require any further information or clarification, please do not hesitate to contact us.</p>
                                
                                <p>We look forward to your valued participation.</p>
                                
                                <div style="margin-top: 40px;">
                                    <p class="d-flex justify-content-end">Sincerely,</p>
                                </div>
                            </div>
                              <div class="mt-4 justify-content-between d-flex row">
                    <div class="col-4">
                        <p><strong>CC:</strong></p>
                    <ul class="gap-1">
                        <li> <t t-if="employee and employee.parent_id">
                            <span t-field="employee.parent_id.job_id.name"/>
                        </t>
                        <t t-else="">(Immediate manager)</t></li>
                    </ul>
                    
                    <t t-set="company_name" t-value="(training.company_id and training.company_id.name) or (employee and employee.company_id and employee.company_id.name) or 'Wagwago'"/>
                    <div><u><b><span t-esc="(company_name.split()[0] if company_name and company_name.strip() else 'Wagwago')"/></b></u></div>
                    </div>
                    
                    <div class="col-4 d-flex justify-content-end">
                        <t t-if="training.company_id and training.company_id.company_stamp">
                            <img t-att-src="image_data_uri(training.company_id.company_stamp)"
                                style="max-height:140px; min-height:140px;"/>
                        </t>
                        <t t-elif="employee and employee.company_id and employee.company_id.company_stamp">
                            <img t-att-src="image_data_uri(employee.company_id.company_stamp)"
                                style="max-height:140px; min-height:140px;"/>
                        </t>
                    </div>

                     <div class="col-4 d-flex justify-content-end">
                        <t t-if="training.authorize_by and training.authorize_by.sign_signature">
                            <img t-att-src="image_data_uri(training.authorize_by.sign_signature)"
                                style="max-height:140px; min-height:140px;"/>
                        </t>
                    </div>
                </div>
                        </div>
                    </t>
                </t>
            </t>
        </t>
    </template>
</odoo>
