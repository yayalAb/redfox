<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Email Body Template -->
    <template id="email_template_hr_contract_body" name="HR Contract Email Body">
        <div style="font-family: 'Times New Roman', serif; font-size: 12pt; line-height: 1.6; padding: 20px;">
                <!-- Reference Number and Date -->
                <div style="text-align: right; margin-bottom: 20px;">
                    <p><strong>Ref No:- <t t-esc="get_ref_no(contract) if get_ref_no else ('WG/' + str(contract.id).zfill(4) + '/2018' if contract.id else 'WG/0000/2018')"/></strong></p>
                    <p><strong>Date:- <t t-esc="current_date_formatted or (current_date.strftime('%B %d, %Y') if current_date and hasattr(current_date, 'strftime') else '')"/></strong></p>
                </div>
                
                <!-- To Section -->
                <div style="margin-bottom: 15px;">
                    <p><strong>To: <t t-if="contract.employee_id.gender == 'male'">Mr. </t><t t-if="contract.employee_id.gender == 'female'">Mrs. </t><span t-field="contract.employee_id.name"/></strong></p>
                    <p t-if="contract.employee_id and contract.employee_id.private_city">
                        <u><b><span t-field="contract.employee_id.private_city"/></b></u>
                    </p>
                    <p t-elif="contract.employee_id and contract.employee_id.address_id and contract.employee_id.address_id.city">
                        <u><b><span t-field="contract.employee_id.address_id.city"/></b></u>
                    </p>
                    <p t-else=""><u><b>Addis Ababa</b></u></p>
                </div>
                
                <!-- Subject -->
                <div style="margin-bottom: 20px; text-align: center;">
                    <p style="white-space: nowrap; display: inline-block;"><strong>Subject: <u>Job Offer Letter</u></strong></p>
                </div>
                
                <!-- Letter Body -->
                <div style="text-align: justify;">
                    <p>Dear <span t-esc="contract.employee_id.name.split()[0] if contract.employee_id and contract.employee_id.name else 'Employee'"/>,</p>
                    
                    <p>We were all very excited to meet and get to know you over the past few days. We have been impressed with your background and would like to formally offer you the position of <strong>
                        <span t-if="contract.employee_id and contract.employee_id.job_id" t-field="contract.employee_id.job_id.name"/>
                        <t t-else="">your position</t>
                    </strong> at <strong><span t-field="contract.company_id.name"/></strong>.</p>
                    
                    <p>This is a full-time position and you will be reporting to <t t-if="contract.employee_id and contract.employee_id.parent_id and contract.employee_id.parent_id.job_id">
                        <strong><span t-field="contract.employee_id.parent_id.job_id.name"/></strong>
                    </t><t t-else="">the General Manager</t>.</p>
                    
                    <p>We will be offering you a monthly gross salary of birr <strong>
                        <span t-esc="'{0:,.2f}'.format(contract.wage or 0)"/>
                    </strong> (<span t-esc="contract.currency_id.amount_to_text(contract.wage or 0)"/> Birr) 
                    <t t-if="contract.salary_grade_value_id or contract.scale_level_id">
                        at the company Grade level <t t-if="contract.salary_grade_value_id"><strong><span t-field="contract.salary_grade_value_id.name"/></strong></t><t t-else="">________</t> 
                        and scale level <t t-if="contract.scale_level_id"><strong><span t-field="contract.scale_level_id.name"/></strong></t><t t-else="">________</t>.
                    </t>
                    <t t-set="has_allowances" t-value="contract.house_rent_allowance or contract.dearness_allowance or contract.travel_allowance or contract.meal_allowance or contract.medical_allowance or contract.position_allowance or contract.transport_home_allowance or contract.transport_work_allowance or contract.fuel_allowance or contract.cash_indemnity_allowance or contract.professional_allowance or contract.other_allowance"/>
                    <t t-if="has_allowances">
                        Additionally, you are entitled to 
                        <t t-if="contract.house_rent_allowance">
                            <strong>House Rent Allowance: birr <span t-esc="'{0:,.2f}'.format(contract.house_rent_allowance)"/></strong> (<span t-esc="contract.currency_id.amount_to_text(contract.house_rent_allowance)"/> Birr)<t t-if="contract.dearness_allowance or contract.travel_allowance or contract.meal_allowance or contract.medical_allowance or contract.position_allowance or contract.transport_home_allowance or contract.transport_work_allowance or contract.fuel_allowance or contract.cash_indemnity_allowance or contract.professional_allowance or contract.other_allowance">, </t>
                        </t>
                        <t t-if="contract.dearness_allowance">
                            <strong>Dearness Allowance: birr <span t-esc="'{0:,.2f}'.format(contract.dearness_allowance)"/></strong> (<span t-esc="contract.currency_id.amount_to_text(contract.dearness_allowance)"/> Birr)<t t-if="contract.travel_allowance or contract.meal_allowance or contract.medical_allowance or contract.position_allowance or contract.transport_home_allowance or contract.transport_work_allowance or contract.fuel_allowance or contract.cash_indemnity_allowance or contract.professional_allowance or contract.other_allowance">, </t>
                        </t>
                        <t t-if="contract.travel_allowance">
                            <strong>Travel Allowance: birr <span t-esc="'{0:,.2f}'.format(contract.travel_allowance)"/></strong> (<span t-esc="contract.currency_id.amount_to_text(contract.travel_allowance)"/> Birr)<t t-if="contract.meal_allowance or contract.medical_allowance or contract.position_allowance or contract.transport_home_allowance or contract.transport_work_allowance or contract.fuel_allowance or contract.cash_indemnity_allowance or contract.professional_allowance or contract.other_allowance">, </t>
                        </t>
                        <t t-if="contract.meal_allowance">
                            <strong>Meal Allowance: birr <span t-esc="'{0:,.2f}'.format(contract.meal_allowance)"/></strong> (<span t-esc="contract.currency_id.amount_to_text(contract.meal_allowance)"/> Birr)<t t-if="contract.medical_allowance or contract.position_allowance or contract.transport_home_allowance or contract.transport_work_allowance or contract.fuel_allowance or contract.cash_indemnity_allowance or contract.professional_allowance or contract.other_allowance">, </t>
                        </t>
                        <t t-if="contract.medical_allowance">
                            <strong>Medical Allowance: birr <span t-esc="'{0:,.2f}'.format(contract.medical_allowance)"/></strong> (<span t-esc="contract.currency_id.amount_to_text(contract.medical_allowance)"/> Birr)<t t-if="contract.position_allowance or contract.transport_home_allowance or contract.transport_work_allowance or contract.fuel_allowance or contract.cash_indemnity_allowance or contract.professional_allowance or contract.other_allowance">, </t>
                        </t>
                        <t t-if="contract.position_allowance">
                            <strong>Position Allowance: birr <span t-esc="'{0:,.2f}'.format(contract.position_allowance)"/></strong> (<span t-esc="contract.currency_id.amount_to_text(contract.position_allowance)"/> Birr)<t t-if="contract.transport_home_allowance or contract.transport_work_allowance or contract.fuel_allowance or contract.cash_indemnity_allowance or contract.professional_allowance or contract.other_allowance">, </t>
                        </t>
                        <t t-if="contract.transport_home_allowance">
                            <strong>Transport (Home) Allowance: birr <span t-esc="'{0:,.2f}'.format(contract.transport_home_allowance)"/></strong> (<span t-esc="contract.currency_id.amount_to_text(contract.transport_home_allowance)"/> Birr)<t t-if="contract.transport_work_allowance or contract.fuel_allowance or contract.cash_indemnity_allowance or contract.professional_allowance or contract.other_allowance">, </t>
                        </t>
                        <t t-if="contract.transport_work_allowance">
                            <strong>Transport (Work) Allowance: birr <span t-esc="'{0:,.2f}'.format(contract.transport_work_allowance)"/></strong> (<span t-esc="contract.currency_id.amount_to_text(contract.transport_work_allowance)"/> Birr)<t t-if="contract.fuel_allowance or contract.cash_indemnity_allowance or contract.professional_allowance or contract.other_allowance">, </t>
                        </t>
                        <t t-if="contract.fuel_allowance">
                            <strong>Fuel Allowance: birr <span t-esc="'{0:,.2f}'.format(contract.fuel_allowance)"/></strong> (<span t-esc="contract.currency_id.amount_to_text(contract.fuel_allowance)"/> Birr)<t t-if="contract.cash_indemnity_allowance or contract.professional_allowance or contract.other_allowance">, </t>
                        </t>
                        <t t-if="contract.cash_indemnity_allowance">
                            <strong>Cash Indemnity Allowance: birr <span t-esc="'{0:,.2f}'.format(contract.cash_indemnity_allowance)"/></strong> (<span t-esc="contract.currency_id.amount_to_text(contract.cash_indemnity_allowance)"/> Birr)<t t-if="contract.professional_allowance or contract.other_allowance">, </t>
                        </t>
                        <t t-if="contract.professional_allowance">
                            <strong>Professional Allowance: birr <span t-esc="'{0:,.2f}'.format(contract.professional_allowance)"/></strong> (<span t-esc="contract.currency_id.amount_to_text(contract.professional_allowance)"/> Birr)<t t-if="contract.other_allowance">, </t>
                        </t>
                        <t t-if="contract.other_allowance">
                            <strong>Other Allowance: birr <span t-esc="'{0:,.2f}'.format(contract.other_allowance)"/></strong> (<span t-esc="contract.currency_id.amount_to_text(contract.other_allowance)"/> Birr)
                        </t>
                        .
                         <t t-if="contract.fuel_allowance or contract.medical_allowance">
                            You will also have 
                                <t t-if="contract.fuel_allowance">company car with fuel</t>
                                <t t-if="contract.fuel_allowance and contract.medical_allowance">, </t>
                                <t t-if="contract.medical_allowance">medical &amp; life insurance plan</t>.
                        
                    </t>
                    
                   
                    </t>
                    </p>
                    
                    
                    
                   
                    
                    <p>Your expected starting date is <strong>
                        <span t-if="contract.date_start" t-field="contract.date_start" t-options='{"widget": "date"}'/>
                        <t t-else="">the start date</t>
                    </strong>. You will be asked to sign an employment agreement at the beginning of your employment.</p>
                    
                    <p>We would like to have your response <strong>
                        <span t-if="contract.date_start">
                            <span t-field="contract.date_start" t-options='{"widget": "date"}'/>
                        </span>
                        <t t-else="">October 9, 2025</t>
                    </strong>. In the meantime, please feel free to contact me via email or phone on 
                    <t t-if="contract.company_id.email">
                        <strong><span t-field="contract.company_id.email"/></strong>
                    </t>
                    <t t-else="">wagwagotrading@gmail.com</t>
                    <t t-if="contract.company_id.phone">
                         or <strong><span t-field="contract.company_id.phone"/></strong>
                    </t>
                    <t t-else=""> or 0930533588</t>, should you have any questions.</p>
                    
                    <p>We are all looking forward to having you on our team.</p>
                    
                    <div style="margin-top: 40px;">
                        <p class="d-flex justify-content-end">Yours sincerely,</p>
                    </div>
                </div>
                  <div class="mt-4 justify-content-between d-flex row">
                    <div class="col-4">
                        <p><strong>CC.</strong></p>
                    <ul class="gap-1">
                        <t t-if="contract.department_id">
                            <li> <span t-field="contract.department_id.name" /></li>
                        </t>
                        <li>Corporate Finance Office</li>
                        <li>Personnel File</li>
                        
                    </ul>
                    
                    <div><u><b><span t-esc="contract.company_id.name.split()[0] if contract.company_id and contract.company_id.name else ''"/></b></u></div>
                    </div>
                    
                    <div class="col-4 d-flex justify-content-end">
                        <t t-if="contract.company_id.company_stamp">
                            <img t-att-src="image_data_uri(contract.company_id.company_stamp)"
                                style="max-height:140px; min-height:140px;"/>
                        </t>
                    </div>
                     <div class="col-4 d-flex justify-content-end">
                        <t t-if="contract.approved_by_id.sign_signature">
                            <img t-att-src="image_data_uri(contract.approved_by_id.sign_signature)"
                                style="max-height:140px; min-height:140px;"/>
                        </t>
                    </div>
                </div>
            </div>
    </template>
</odoo>
