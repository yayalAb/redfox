<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Acting Letter Email Body Template -->
    <template id="email_template_acting_letter_body" name="Acting Letter Email Body">
        <div style="font-family: 'Times New Roman', serif; font-size: 12pt; line-height: 1.6; padding: 20px;">
                <!-- Reference Number and Date -->
                <div style="text-align: right; margin-bottom: 20px;">
                    <p><strong>Ref No ፡- <t t-esc="get_ref_no(contract) if get_ref_no else (ref_no if ref_no else ('WG/' + str(contract.id).zfill(4) + '/2018' if contract.id else 'WG/0000/2018'))"/></strong></p>
                    <p><strong>Date ፡- <t t-esc="current_date_formatted or (current_date.strftime('%B %d, %Y') if current_date and hasattr(current_date, 'strftime') else '')"/></strong></p>
                </div>
                
                <!-- To Section -->
                <div style="margin-bottom: 15px;">
                    <p><strong>To: <t t-if="contract.employee_id.gender == 'male'">Mr. </t><t t-if="contract.employee_id.gender == 'female'">Mrs. </t><span t-field="contract.employee_id.name"/><t t-if="contract.employee_id.identification_id"> /<span t-field="contract.employee_id.identification_id"/></t> /</strong></p>
                    <p t-if="contract.employee_id and contract.employee_id.private_city">
                        <u><b><span t-field="contract.employee_id.private_city"/></b></u>
                    </p>
                    <p t-elif="contract.employee_id and contract.employee_id.address_id and contract.employee_id.address_id.city">
                        <u><b><span t-field="contract.employee_id.address_id.city"/></b></u>
                    </p>
                    <p t-else=""><u><b>Addis Ababa</b></u></p>
                </div>
                
                <!-- Subject -->
                <div style="margin-bottom: 20px; text-align: center;">
                    <p style="white-space: nowrap; display: inline-block;"><strong>Subject: <u>Acting Letter</u></strong></p>
                </div>
                
                <!-- Letter Body -->
                <div style="text-align: justify;">
                    <p>Dear <span t-esc="contract.employee_id.name.split()[0] if contract.employee_id and contract.employee_id.name else 'Employee'"/>,</p>
                    
                    <p>We are pleased to inform you of your temporary appointment as the <strong>
                        <span t-if="contract.employee_id and contract.employee_id.job_id" t-field="contract.employee_id.job_id.name"/>
                        <t t-else="">Chief Executive Officer</t>
                    </strong> of the <strong>
                        <span t-if="contract.department_id" t-field="contract.department_id.name"/>
                        <t t-else="">Wagwago Corporate Office Planning Department</t>
                    </strong>, effective <strong>
                        <span t-if="contract.date_start" t-field="contract.date_start" t-options='{"widget": "date"}'/>
                        <t t-else="">November 6, 2025</t>
                    </strong>. In this role, you will report directly to <t t-if="contract.employee_id and contract.employee_id.parent_id and contract.employee_id.parent_id.job_id">
                        <strong><span t-field="contract.employee_id.parent_id.job_id.name"/></strong>
                    </t><t t-else="">the CEO</t>.</p>
                    
                    <p>This appointment reflects our recognition of your exceptional leadership capabilities, expertise, and dedication to enhancing our company's operations and commitment to growth and sustainability. We believe that your leadership will significantly contribute to our planning initiatives and overall corporate strategy.</p>
                    
                    <p>To ensure a smooth transition into your new role, we encourage you to arrange a meeting with <t t-if="contract.employee_id and contract.employee_id.parent_id">
                        <strong><span t-field="contract.employee_id.parent_id.name"/></strong>
                    </t><t t-else="">Mr. Anwar Nurhsien</t>. This meeting will provide you with an opportunity to discuss the specifics of your responsibilities and address any questions you may have.</p>
                    
                    <p>We view this appointment as an opportunity for you to showcase your talents in a new context. Your commitment to our organization is greatly appreciated, and we look forward to your contributions in this capacity.</p>
                    
                    <p>Should you have any questions or require further information, please do not hesitate to reach out.</p>
                    
                    <p>Congratulations on your new responsibility!</p>
                    
                    <div style="margin-top: 40px;">
                        <p class="d-flex justify-content-end">Sincerely,</p>
                    </div>
                </div>
                  <div class="mt-4 justify-content-between d-flex row">
                    <div class="col-4">
                        <p><strong>CC:</strong></p>
                    <ul class="gap-1">
                        <li>All Corporate Office</li>
                        <li>Personnel File</li>
                    </ul>
                    
                    <div><u><b><span t-esc="contract.company_id.name.split()[0] if contract.company_id and contract.company_id.name else ''"/></b></u></div>
                    </div>
                    
                    <div class="col-4 d-flex justify-content-end">
                        <t t-if="contract.company_id.company_stamp">
                            <img t-att-src="image_data_uri(contract.company_id.company_stamp)"
                                style="max-height:140px; min-height:140px;"/>
                        </t>
                    </div>
                     <div class="col-4 d-flex justify-content-end">
                        <t t-if="contract.approved_by_id.sign_signature">
                            <img t-att-src="image_data_uri(contract.approved_by_id.sign_signature)"
                                style="max-height:140px; min-height:140px;"/>
                        </t>
                    </div>
                </div>
            </div>
    </template>
</odoo>
