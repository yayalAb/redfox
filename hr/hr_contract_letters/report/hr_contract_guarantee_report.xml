<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Guarantee Letter Report Action -->
    <record id="action_report_guarantee" model="ir.actions.report">
        <field name="name">Print Guarantee Letter</field>
        <field name="model">hr.contract</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">hr_contract_letters.report_guarantee_document</field>
        <field name="report_file">hr_contract_letters.report_guarantee_document</field>
        <field name="print_report_name">'Guarantee Letter - %s' % (object.employee_id.name if object.employee_id else 'Guarantee')</field>
        <field name="binding_model_id" ref="hr_contract.model_hr_contract"/>
        <field name="binding_type">report</field>
    </record>

    <!-- Guarantee Letter Report Template -->
    <template id="report_guarantee_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="contract">
                <t t-call="web.external_layout">
                    <div class="page" style="font-family: 'Times New Roman', serif; font-size: 16pt; line-height: 1.6; padding: 20px;">
                        <t t-set="doc_title" t-value="'ዋስትናን ይመለከታል'" />
                            <t t-set="doc_number" t-value="'OF/WW/HRGS/029'" />
                            <t t-set="issue_number" t-value="'1'" />
                        <!-- Letter Number and Date -->
                        <div style="text-align: left; margin-bottom: 20px;">
                            <p class="d-flex justify-content-end"><strong>የደብዳቤ ቁጥር፡- <t t-esc="get_ref_no(contract) if get_ref_no else ('WG/' + str(contract.id).zfill(4) + '/2018' if contract.id else 'WG/0000/2018')"/></strong> </p>
                            <p class="d-flex justify-content-end"><strong>ቀን ፡- <t t-esc="current_date_formatted or (current_date.strftime('%B %d, %Y') if current_date and hasattr(current_date, 'strftime') else '')"/></strong></p>
                        </div>
                        
                        <!-- Company Name and Address -->
                        <div style="margin-bottom: 20px;">
                            <p><strong><span t-field="contract.company_id.name"/></strong></p>
                            <p>
                                <t t-if="contract.company_id.street">
                                    <span t-field="contract.company_id.street"/>
                                </t>
                                <t t-if="contract.company_id.city">
                                    <t t-if="contract.company_id.street">, </t>
                                    <span t-field="contract.company_id.city"/>
                                </t>
                                <t t-else="">
                                    አዲስ አበባ
                                </t>
                            </p>
                        </div>
                        
                        <!-- Subject -->
                        <div style="margin-bottom: 20px; text-align: center;">
                            <p style="white-space: nowrap; display: inline-block;"><strong>ጉዳዩ፡- ዋስትናን ይመለከታል፤</strong></p>
                        </div>
                        
                        <!-- Letter Body -->
                        <div style="text-align: justify;">
                            <p>የድርጅታችን ባልደረባ የሆኑ <t t-if="contract.employee_id.gender == 'male'">አቶ </t><t t-if="contract.employee_id.gender == 'female'">ወ/ሮ </t><strong><span t-field="contract.employee_id.name"/><t t-if="contract.employee_id.identification_id">/<span t-field="contract.employee_id.identification_id"/></t></strong> ለ<strong><t t-esc="env.context.get('guarantee_employee_name', '_______________')"/></strong> የስራ ቅጥር ዋስ መሆን እንዲችሉ የቅጥር ሁኔታቸው እና የወር ደመወዛቸው ተጠቅሶ ለ<strong><span t-field="contract.company_id.name"/></strong> ደብዳቤ እንዲጻፍላቸው <strong><t t-esc="env.context.get('guarantee_company_name', '_______________')"/></strong> በጻፉት ማመልከቻ ጠይቀዋል።</p>
                            
                            <p>በመሆኑም <t t-if="contract.employee_id.gender == 'male'">አቶ </t><t t-if="contract.employee_id.gender == 'female'">ወ/ሮ </t><strong><span t-field="contract.employee_id.name"/><t t-if="contract.employee_id.identification_id">/<span t-field="contract.employee_id.identification_id"/></t></strong> የድርጅታችን ቋሚ ሰራተኛ ሲሆኑ ፤ በወር ብር <strong><span t-esc="'{0:,.2f}'.format(contract.wage)"/></strong> /<span t-esc="contract.currency_id.amount_to_text(contract.wage)"/> ብር/ ደመወዝ እየተከፈላቸው በማገልገል ላይ ያሉ መሆናቸውን እየገለጽን፤ በጡረታ ወይም በተለያዩ ምክንያት ከስራ ቢለቁ ወይም ቢዛወሩ በቅድምያ የምናሳውቅ መሆኑን በትህትና እንገልጻለን።</p>
                            
                            <p>ከሰላምታ ጋር</p>
                        </div>
                        
                        <!-- CC Section -->
                         <div class="mt-4 justify-content-between d-flex">
                                <div>
                                    <p><strong>ግልባጭ፦</strong></p>
                                    <ul style="list-style: none; padding-left: 0;">
                                        <li>ለሪከርድ</li>
                                    </ul>
                                
                                <div><u><b><span t-esc="contract.company_id.name.split()[0] if contract.company_id and contract.company_id.name else ''"/></b></u></div>
                                </div>
                               <div class="justify-content-center d-col">
                                    <div class="ms-5"><span t-field="contract.approved_by_id.name" /></div>
                                        <t t-if="contract.approved_by_id.sign_signature">
                                            <img t-att-src="image_data_uri(contract.approved_by_id.sign_signature)"
                                                style="max-height:140px; min-height:140px;"/>
                                        </t>
                                    </div>
                                    <div class="me-4">
                                        <t t-if="contract.company_id.company_stamp">
                                            <img t-att-src="image_data_uri(contract.company_id.company_stamp)"
                                                style="max-height:140px; min-height:140px;"/>
                                        </t>
                                    </div>
                                 </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
