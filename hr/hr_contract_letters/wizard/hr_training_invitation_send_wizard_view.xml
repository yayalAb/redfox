<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_hr_training_invitation_send_wizard_form" model="ir.ui.view">
        <field name="name">hr.training.invitation.send.wizard.form</field>
        <field name="model">hr.training.invitation.send.wizard</field>
        <field name="arch" type="xml">
            <form string="Print/Send Training Invitation">
                <group>
                    <field name="training_requisition_id" readonly="1"/>
                </group>
                <group>
                    <field name="partner_ids" 
                           widget="many2many_tags_email"
                           placeholder="Recipients (To)..."
                           options="{'no_quick_create': True}"
                           context="{'show_email': True}"
                           required="1"
                           help="Participants are automatically included as recipients"/>
                    <field name="cc_partner_ids" 
                           widget="many2many_tags_email"
                           placeholder="CC recipients..."
                           options="{'no_quick_create': True}"
                           context="{'show_email': True}"
                           help="CC: Immediate Manager, Company"/>
                    <field name="subject" placeholder="Email subject..."/>
                </group>
                <field name="body" widget="html" placeholder="Email message..."/>
                <footer>
                    <button string="Send Email" name="action_send_email" type="object" 
                            class="btn-primary"/>
                    <button string="Print Only" name="action_print_only" type="object" 
                            class="btn-secondary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_hr_training_invitation_send_wizard" model="ir.actions.act_window">
        <field name="name">Print/Send Training Invitation</field>
        <field name="res_model">hr.training.invitation.send.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_training_requisition_id': active_id}</field>
    </record>
</odoo>
