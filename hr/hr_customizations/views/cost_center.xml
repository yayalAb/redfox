<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <data>

    <record id="employee_hr_cost_center_action" model="ir.actions.act_window">
        <field name="name">hr.cost.center</field>
        <field name="res_model">hr.cost.center</field>
        <field name="type">ir.actions.act_window</field>
        <field name="view_mode">list,form</field>
        <field name="context" eval="{'search_default_my_courses': 1}"/>
        <field name="domain">[]</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Add a new hr cost center
            </p>

        </field>
    </record>
    <record id="employee_hr_cost_center_view_form" model="ir.ui.view">
        <field name="name">hr cost center</field>
        <field name="model">hr.cost.center</field>
        <field name="arch" type="xml">
            <form string="Employee Insurance">
                <sheet>
                    <group>
                        <group>
                               <field name="cost_center"/>

                        </group>


                    </group>
                </sheet>

            </form>
        </field>
    </record>
    <record id="employee_hr_cost_center_view_tree" model="ir.ui.view">
        <field name="name">hr.cost.center</field>
        <field name="model">hr.cost.center</field>
        <field name="arch" type="xml">
            <list>

                 <field name="cost_center"/>

            </list>
        </field>
    </record>



    <menuitem id="menu_employee_cost_center"
             name="Cost Center"
             parent="hr.menu_human_resources_configuration"
             action="employee_hr_cost_center_action"/>
</data>

</odoo>
