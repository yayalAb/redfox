<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="fleet_vehicle_view_form_inherit_rental" model="ir.ui.view">
        <field name="name">fleet.vehicle.form.inherit.rental</field>
        <field name="model">fleet.vehicle</field>
        <field name="inherit_id" ref="fleet.fleet_vehicle_view_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">
                <field name="is_rented" invisible="1"/>
            </xpath>

            <!-- 2. Hide Chassis Number (vin_sn) if it is a rental -->
            <xpath expr="//field[@name='vin_sn']" position="attributes">
                <attribute name="invisible">is_rented</attribute>
            </xpath>

            <!-- 3. Handle Registration Date / Rented Date logic -->
            <!-- We hide the original field -->
            <xpath expr="//field[@name='acquisition_date']" position="attributes">
                <attribute name="invisible">is_rented</attribute>
            </xpath>

            <!-- We add a duplicate field with a different label that shows ONLY when is_rented is true -->
            <xpath expr="//field[@name='acquisition_date']" position="after">
                <field name="acquisition_date" 
                       string="Rented date" 
                       invisible="not is_rented"
                       help="The date where the rented vehicle is accepted"/>
            </xpath>

        </field>
    </record>
</odoo>