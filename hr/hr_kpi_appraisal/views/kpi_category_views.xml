<?xml version="1.0" encoding="utf-8"?>
<odoo>
     <!-- LIST VIEW -->
    <record id="view_kpi_category_list" model="ir.ui.view">
        <field name="name">kpi.category.list</field>
        <field name="model">appraisal.kpi.category</field>
        <field name="arch" type="xml">
            <list string="KPI Categories">
                <field name="name"/>
                
            </list>
        </field>
    </record>
    <record id="view_kpi_category_form" model="ir.ui.view">
        <field name="name">kpi.category.form</field>
        <field name="model">appraisal.kpi.category</field>
        <field name="arch" type="xml">
            <form string="KPI Category">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="e.g., Operational Efficiency"/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="description"
                                placeholder="Describe what this KPI category covers…"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kpi_category_config" model="ir.actions.act_window">
        <field name="name">KPI Categories</field>
        <field name="res_model">appraisal.kpi.category</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new KPI Category.
            </p>
        </field>
    </record>
</odoo>