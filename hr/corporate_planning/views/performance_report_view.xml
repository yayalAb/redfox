<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FORM VIEW -->
    <record id="view_performance_report_form" model="ir.ui.view">
        <field name="name">performance.report.form</field>
        <field name="model">corporate.performance.report</field>
        <field name="arch" type="xml">
            <form string="Quarterly Performance Report">
                <header>
                    <button name="action_generate_data" string="1. Fetch Targets from Plan" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_submit" string="Submit Report" type="object" class="oe_highlight" invisible="state != 'generated'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'submitted'" groups="base.group_user"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,generated,submitted,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="department_id"/>
                            <field name="plan_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="fiscal_year"/>
                            <field name="quarter" widget="radio"/>
                        </group>
                    </group>

                    <notebook>
                        
                        <!-- TAB 1: ACTIVITY PERFORMANCE -->
                        <page string="1. Activity Performance">
                            <field name="op_activity_ids">
                                <list editable="bottom" create="0" delete="0"> <!-- Create=0 prevents adding manual lines -->
                                    <field name="activity_master_id"/>
                                    <field name="uom_id"/>
                                    <field name="annual_target" optional="hide"/>
                                    
                                    <!-- LAST YEAR -->
                                    <field name="ly_quarter_plan" string="LY Plan" optional="show"/>
                                    <field name="ly_quarter_actual" string="LY Actual" optional="show"/>
                                    <field name="ly_percent_achieved" string="LY %" widget="progressbar" optional="show"/>
                                    
                                    <!-- THIS QUARTER -->
                                    <field name="quarter_plan" string="Plan"/>
                                    <field name="quarter_actual" string="Actual"/>
                                    <field name="percent_achieved" widget="progressbar" decoration-danger="percent_achieved &lt; 50"/>
                                    <field name="variance" decoration-danger="variance &lt; 0"/>
                                    
                                    <field name="remark"/>
                                </list>
                            </field>
                        </page>

                        <!-- TAB 2: FINANCIAL PERFORMANCE -->
                        <page string="2. Financial Performance">
                            <field name="financial_ids">
                                <list editable="bottom" create="0" delete="0" decoration-bf="category in ('revenue','cos')">
                                    <field name="category" optional="hide"/>
                                    <field name="item_id"/>
                                    <field name="uom_id" optional="hide"/>
                                    <field name="annual_budget" optional="hide"/>
                                    
                                    <!-- LAST YEAR -->
                                    <field name="ly_quarter_plan" string="LY Plan" optional="show" widget="monetary"/>
                                    <field name="ly_quarter_actual" string="LY Actual" optional="show" widget="monetary"/>
                                    <field name="ly_percent_utilization" string="LY %" widget="progressbar" optional="show"/>
                                    
                                    <!-- THIS QUARTER -->
                                    <field name="quarter_plan_amount" sum="Total Plan" widget="monetary"/>
                                    <field name="quarter_actual_amount" sum="Total Actual" widget="monetary"/>
                                    <field name="percent_utilization" widget="progressbar"/>
                                    <field name="variance_amount" widget="monetary" decoration-danger="variance_amount &lt; 0"/>
                                    
                                    <field name="remark"/>
                                </list>
                            </field>
                        </page>

                        <!-- TAB 3: KPI PERFORMANCE -->
                        <page string="3. KPI Dashboard">
                            <field name="kpi_ids">
                                <list editable="bottom" create="0" delete="0">
                                    <field name="perspective"/>
                                    <field name="kpi_id"/>
                                    <field name="weight"/>
                                    <field name="annual_target" optional="hide"/>
                                    
                                    <!-- LAST YEAR -->
                                    <field name="ly_quarter_target" string="LY Target" optional="show"/>
                                    <field name="ly_quarter_actual" string="LY Actual" optional="show"/>
                                    <field name="ly_percent_achieved" string="LY %" widget="progressbar" optional="show"/>
                                    
                                    <!-- THIS QUARTER -->
                                    <field name="quarter_target"/>
                                    <field name="quarter_actual"/>
                                    <field name="percent_achieved" widget="progressbar" decoration-danger="percent_achieved &lt; 70"/>
                                    
                                    <field name="remark"/>
                                </list>
                            </field>
                        </page>

                        <!-- TAB 4: CAPEX PERFORMANCE -->
                        <page string="4. Capex Performance">
                            <field name="capex_ids">
                                <list editable="bottom" create="0" delete="0">
                                    <field name="capex_item_id"/>
                                    
                                    <!-- PHYSICAL PERFORMANCE -->
                                    <field name="ly_qty_achieved" string="LY Qty %" widget="progressbar" optional="hide"/>
                                    <field name="quarter_plan_qty" string="Plan Qty"/>
                                    <field name="quarter_actual_qty" string="Act Qty"/>
                                    <field name="qty_achieved_percent" widget="progressbar"/>
                                    
                                    <!-- FINANCIAL PERFORMANCE -->
                                    <field name="ly_budget_utilized" string="LY Budg %" widget="progressbar" optional="hide"/>
                                    <field name="quarter_budget_etb" string="Budget" widget="monetary"/>
                                    <field name="quarter_actual_cost" string="Cost" widget="monetary"/>
                                    <field name="budget_utilized_percent" widget="progressbar"/>
                                    
                                    <field name="user_department"/>
                                    <field name="remark"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <!-- LIST VIEW (Needed for the Action) -->
    <record id="view_performance_report_tree" model="ir.ui.view">
        <field name="name">performance.report.list</field>
        <field name="model">corporate.performance.report</field>
        <field name="arch" type="xml">
            <list string="Performance Reports">
                <field name="name"/>
                <field name="department_id"/>
                <field name="fiscal_year"/>
                <field name="quarter"/>
                <field name="state" widget="badge" decoration-success="state == 'approved'"/>
            </list>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_performance_report" model="ir.actions.act_window">
        <field name="name">Performance Reports</field>
        <field name="res_model">corporate.performance.report</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>