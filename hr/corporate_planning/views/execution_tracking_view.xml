<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ==================================================== -->
    <!-- 1. ACTIVITY EXECUTION TRACKING                       -->
    <!-- ==================================================== -->

    <!-- Search View (Filters) -->
    <record id="search_execution_activity" model="ir.ui.view">
        <field name="name">execution.activity.search</field>
        <field name="model">corporate.execution.activity</field>
        <field name="arch" type="xml">
            <search>
                <field name="department_id"/>
                <field name="activity_master_id"/>
                <field name="fiscal_year"/>
                <filter string="Current Year" name="current_year" domain="[('fiscal_year', '=', context_today().strftime('%Y'))]"/>
                <group expand="1" string="Group By">
                    <filter string="Department" name="grp_dept" context="{'group_by': 'department_id'}"/>
                    <filter string="Activity" name="grp_act" context="{'group_by': 'activity_master_id'}"/>
                    <filter string="Month" name="grp_month" context="{'group_by': 'period_month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Form view-->

    <record id="form_execution_activity" model="ir.ui.view">
        <field name="name">execution.activity.form</field>
        <field name="model">corporate.execution.activity</field>
        <field name="arch" type="xml">
            <form string="Activity Actual Log" create="0" edit="0">
                <sheet>
                    <group>
                        <field name="fiscal_year"/>
                        <field name="period_month"/>
                        <field name="department_id"/>
                        <field name="activity_master_id"/>
                        <field name="actual_qty"/>
                        <field name="uom_id"/>
                        <field name="state" widget="badge"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Tree View (Read Only) -->
    <record id="tree_execution_activity" model="ir.ui.view">
        <field name="name">execution.activity.tree</field>
        <field name="model">corporate.execution.activity</field>
        <field name="arch" type="xml">
            <list string="Activity Logs" create="0" edit="0" delete="0" decoration-info="state == 'draft'">
                <field name="fiscal_year" optional="hide"/>
                <field name="period_month"/>
                <field name="department_id"/>
                <field name="activity_master_id"/>
                <field name="actual_qty" sum="Total Qty"/>
                <field name="uom_id"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="pivot_execution_activity" model="ir.ui.view">
        <field name="name">execution.activity.pivot</field>
        <field name="model">corporate.execution.activity</field>
        <field name="arch" type="xml">
            <pivot string="Activity Analysis" disable_linking="True">
                <field name="department_id" type="row"/>
                <field name="activity_master_id" type="row"/>
                <field name="period_month" type="col"/>
                <field name="actual_qty" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Graph View -->
    <record id="graph_execution_activity" model="ir.ui.view">
        <field name="name">execution.activity.graph</field>
        <field name="model">corporate.execution.activity</field>
        <field name="arch" type="xml">
            <graph string="Activity Trends" type="line" sample="1">
                <field name="period_month"/>
                <field name="actual_qty" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_track_activity" model="ir.actions.act_window">
        <field name="name">Activity Actuals</field>
        <field name="res_model">corporate.execution.activity</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="context">{'search_default_grp_dept': 1}</field>
    </record>


    <!-- ==================================================== -->
    <!-- 2. FINANCIAL EXECUTION TRACKING                      -->
    <!-- ==================================================== -->

    <record id="search_execution_financial" model="ir.ui.view">
        <field name="name">execution.financial.search</field>
        <field name="model">corporate.execution.financial</field>
        <field name="arch" type="xml">
            <search>
                <field name="department_id"/>
                <field name="item_id"/>
                <field name="category"/>
                <filter string="Revenue" name="rev" domain="[('category', '=', 'revenue')]"/>
                <filter string="Expense" name="exp" domain="[('category', 'in', ['cos', 'opex'])]"/>
                <group expand="1" string="Group By">
                    <filter string="Category" name="grp_cat" context="{'group_by': 'category'}"/>
                    <filter string="Department" name="grp_dept" context="{'group_by': 'department_id'}"/>
                    <filter string="Item" name="grp_item" context="{'group_by': 'item_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="form_execution_financial" model="ir.ui.view">
        <field name="name">execution.financial.form</field>
        <field name="model">corporate.execution.financial</field>
        <field name="arch" type="xml">
            <form string="Financial Actual Log" create="0" edit="0">
                <sheet>
                    <group>
                        <field name="period_month"/>
                        <field name="department_id"/>
                        <field name="category"/>
                        <field name="item_id"/>
                        <field name="actual_amount" widget="monetary"/>
                        <field name="state" widget="badge"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="tree_execution_financial" model="ir.ui.view">
        <field name="name">execution.financial.tree</field>
        <field name="model">corporate.execution.financial</field>
        <field name="arch" type="xml">
            <list string="Financial Logs" create="0" edit="0" delete="0" decoration-success="category=='revenue'" decoration-danger="category in ('cos','opex')">
                <field name="period_month"/>
                <field name="department_id"/>
                <field name="category" widget="badge"/>
                <field name="item_id"/>
                <field name="actual_amount" sum="Total Amount" widget="monetary"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="pivot_execution_financial" model="ir.ui.view">
        <field name="name">execution.financial.pivot</field>
        <field name="model">corporate.execution.financial</field>
        <field name="arch" type="xml">
            <pivot string="Financial Analysis" disable_linking="True">
                <field name="category" type="row"/>
                <field name="item_id" type="row"/>
                <field name="period_month" type="col"/>
                <field name="actual_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="graph_execution_financial" model="ir.ui.view">
        <field name="name">execution.financial.graph</field>
        <field name="model">corporate.execution.financial</field>
        <field name="arch" type="xml">
            <graph string="Financial Performance" type="bar" stacked="True">
                <field name="period_month"/>
                <field name="category"/>
                <field name="actual_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_track_financial" model="ir.actions.act_window">
        <field name="name">Financial Actuals</field>
        <field name="res_model">corporate.execution.financial</field>
        <field name="view_mode">list,pivot,graph,form</field>
        <field name="context">{'search_default_grp_cat': 1}</field>
    </record>


    <!-- ==================================================== -->
    <!-- 3. CAPEX EXECUTION TRACKING                          -->
    <!-- ==================================================== -->

    <record id="search_execution_capex" model="ir.ui.view">
        <field name="name">execution.capex.search</field>
        <field name="model">corporate.execution.capex</field>
        <field name="arch" type="xml">
            <search>
                <field name="department_id"/>
                <field name="capex_item_id"/>
                <group expand="1" string="Group By">
                    <filter string="Department" name="grp_dept" context="{'group_by': 'department_id'}"/>
                    <filter string="Asset/Item" name="grp_item" context="{'group_by': 'capex_item_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="form_execution_capex" model="ir.ui.view">
        <field name="name">execution.capex.form</field>
        <field name="model">corporate.execution.capex</field>
        <field name="arch" type="xml">
            <form string="Capex Actual Log" create="0" edit="0">
                <sheet>
                    <group>
                        <field name="period_month"/>
                        <field name="department_id"/>
                        <field name="capex_item_id"/>
                        <field name="actual_qty"/>
                        <field name="actual_cost" widget="monetary"/>
                        <field name="state" widget="badge"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="tree_execution_capex" model="ir.ui.view">
        <field name="name">execution.capex.tree</field>
        <field name="model">corporate.execution.capex</field>
        <field name="arch" type="xml">
            <list string="Capex Logs" create="0" edit="0" delete="0">
                <field name="period_month"/>
                <field name="department_id"/>
                <field name="capex_item_id"/>
                <field name="actual_qty" sum="Total Qty"/>
                <field name="actual_cost" sum="Total Cost" widget="monetary"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="pivot_execution_capex" model="ir.ui.view">
        <field name="name">execution.capex.pivot</field>
        <field name="model">corporate.execution.capex</field>
        <field name="arch" type="xml">
            <pivot string="Capex Analysis">
                <field name="capex_item_id" type="row"/>
                <field name="period_month" type="col"/>
                <field name="actual_cost" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_track_capex" model="ir.actions.act_window">
        <field name="name">Capex Actuals</field>
        <field name="res_model">corporate.execution.capex</field>
        <field name="view_mode">list,pivot,graph,form</field>
    </record>


    <!-- ==================================================== -->
    <!-- 4. OKR EXECUTION TRACKING                            -->
    <!-- ==================================================== -->

    <record id="search_execution_okr" model="ir.ui.view">
        <field name="name">execution.okr.search</field>
        <field name="model">corporate.execution.okr</field>
        <field name="arch" type="xml">
            <search>
                <field name="department_id"/>
                <field name="employee_id"/>
                <field name="okr_line_id"/>
                <group expand="1" string="Group By">
                    <filter string="Department" name="grp_dept" context="{'group_by': 'department_id'}"/>
                    <filter string="Employee" name="grp_emp" context="{'group_by': 'employee_id'}"/>
                    <filter string="Key Result" name="grp_kr" context="{'group_by': 'okr_line_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="form_execution_okr" model="ir.ui.view">
        <field name="name">execution.okr.form</field>
        <field name="model">corporate.execution.okr</field>
        <field name="arch" type="xml">
            <form string="OKR Actual Log" create="0" edit="0">
                <sheet>
                    <group>
                        <field name="period_month"/>
                        <field name="department_id"/>
                        <field name="employee_id"/>
                        <field name="okr_line_id"/>
                        <field name="actual_result" widget="percentage"/>
                        <field name="state" widget="badge"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="tree_execution_okr" model="ir.ui.view">
        <field name="name">execution.okr.tree</field>
        <field name="model">corporate.execution.okr</field>
        <field name="arch" type="xml">
            <list string="OKR Progress Logs" create="0" edit="0" delete="0">
                <field name="period_month"/>
                <field name="department_id"/>
                <field name="employee_id"/>
                <field name="okr_line_id"/>
                <field name="actual_result" string="Result %" widget="progressbar"/>
                <field name="state" widget="badge"/>
            </list>
        </field>
    </record>

    <record id="graph_execution_okr" model="ir.ui.view">
        <field name="name">execution.okr.graph</field>
        <field name="model">corporate.execution.okr</field>
        <field name="arch" type="xml">
            <graph string="OKR Progress" type="line">
                <field name="period_month"/>
                <field name="actual_result" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_track_okr" model="ir.actions.act_window">
        <field name="name">OKR Actuals</field>
        <field name="res_model">corporate.execution.okr</field>
        <field name="view_mode">list,graph,pivot,form</field>
    </record>

</odoo>