<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 1. TREE VIEW -->
    <record id="view_budget_project_list" model="ir.ui.view">
        <field name="name">budget.project.list</field>
        <field name="model">corporate.planning.budget.project</field>
        <field name="arch" type="xml">
            <list string="Project Plans">
                <field name="name"/>
                <field name="department_id"/>
                <field name="fiscal_year"/>
                <field name="total_project_budget" sum="Total Budget" widget="monetary" decoration-bf="1"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-success="state == 'approved'"/>
            </list>
        </field>
    </record>

    <!-- 2. FORM VIEW -->
    <record id="view_budget_project_form" model="ir.ui.view">
        <field name="name">budget.project.form</field>
        <field name="model">corporate.planning.budget.project</field>
        <field name="arch" type="xml">
            <form string="Project Budget Plan">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'confirmed'" groups="base.group_user"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'" />
                    <button name="action_cancel" string="Cancel" type="object"  invisible="state not in ('draft', 'confirmed')" />
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. 2018 Manufacturing Project Plan"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id" options="{'no_create': True}"/>
                            <field name="department_id"/>
                            <field name="analytic_account_id" options="{'no_create': True}"/>
                            <field name="linked_budget_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="fiscal_year"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Project Details">
                            <field name="line_ids" widget="section_and_note_one2many">
                                <list editable="bottom">
                                    <control>
                                        <create name="add_line_control" string="Add a Component"/>
                                        <create name="add_section_control" string="Add a Project Group (Section)" context="{'default_display_type': 'line_section'}"/>
                                        <create name="add_note_control" string="Add a Note" context="{'default_display_type': 'line_note'}"/>
                                    </control>
                                    
                                    <field name="sequence" widget="handle"/>
                                    <field name="display_type" invisible="1"/>
                                    
                                    <field name="name" widget="section_and_note_text" string="Component / Project"/>
                                    
                                    <field name="quantity"/>
                                    <field name="uom_id" options="{'no_create': True}" string="Unit"/>
                                    
                                    <field name="start_date" optional="hide"/>
                                    <field name="end_date" optional="hide"/>
                                    <!-- <field name="expense_type" optional="show" widget="label_selection" 
                                        options="{'classes': {'capex': 'success', 'opex': 'warning'}}"/> -->
                                    <field name="current_status"/>
                                    
                                    <field name="budget_amount" widget="monetary" sum="Total"/>
                                    <field name="remark"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_project_budget" class="oe_subtotal_footer_separator" widget="monetary"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <!-- 3. ACTION -->
    <record id="action_budget_project_planning" model="ir.actions.act_window">
        <field name="name">Project Planning</field>
        <field name="res_model">corporate.planning.budget.project</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Project Budget Plan.
            </p>
        </field>
    </record>

</odoo>