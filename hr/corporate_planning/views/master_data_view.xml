<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 1. FORM VIEW -->
    <record id="view_strategy_type_form" model="ir.ui.view">
        <field name="name">strategy.type.form</field>
        <field name="model">corporate.strategy.type</field>
        <field name="arch" type="xml">
            <form string="Strategy Type">
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. Cost Leadership"/></h1>
                    </div>
                    <group>
                        <field name="description"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 2. TREE VIEW -->
    <record id="view_strategy_type_tree" model="ir.ui.view">
        <field name="name">strategy.type.tree</field>
        <field name="model">corporate.strategy.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- 3. ACTION -->
    <record id="action_strategy_type_config" model="ir.actions.act_window">
        <field name="name">Business Strategy Types</field>
        <field name="res_model">corporate.strategy.type</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Define business strategies (e.g., Differentiation, Cost Leadership).
            </p>
        </field>
    </record>
</odoo>