<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- FORM VIEW -->
    <record id="view_strategy_doc_form" model="ir.ui.view">
        <field name="name">strategy.doc.form</field>
        <field name="model">corporate.strategy.document</field>
        <field name="arch" type="xml">
            <form string="5-Year Strategic Plan">
                <header>
                    <!-- 1. SUBMIT: Visible only in 'draft' -->
                    <button name="action_submit_for_approval" 
                            string="Submit for Approval" 
                            type="object" 
                            class="oe_highlight" 
                            invisible="state != 'draft'" 
                            groups="corporate_planning.group_planning_strategist,corporate_planning.group_planning_manager"/>

                    <!-- 2. APPROVE: Visible only in 'submitted' -->
                    <button name="action_approve" 
                            string="Approve" 
                            type="object" 
                            class="oe_highlight" 
                            invisible="state != 'submitted'" 
                            groups="corporate_planning.group_planning_manager"/>

                    <!-- 3. REVISE: Visible only in 'active' (Fixed from 'approved') -->
                    <button name="action_revise" 
                            string="Revise" 
                            type="object" 
                            invisible="state != 'active'" 
                            groups="corporate_planning.group_planning_manager"/>

                    <!-- Statusbar -->
                    <field name="state" widget="statusbar" statusbar_visible="draft,submitted,active"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Vision 2030"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="start_year"/>
                            <field name="end_year"/>
                        </group>
                        <group>
                            <field name="strategy_doc_file" filename="filename"/>
                            <field name="filename" invisible="1"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Vision" name="page_vision">
                            <div class="alert alert-info" role="alert">
                                <strong>Vision:</strong> Where do we want to be in the future?
                            </div>
                            <field name="vision" placeholder="Enter the 5-Year Vision Statement here..."/>
                        </page>

                        <!-- PAGE 2: MISSION -->
                        <page string="Mission" name="page_mission">
                            <div class="alert alert-success" role="alert">
                                <strong>Mission:</strong> What is our core purpose? Why do we exist?
                            </div>
                            <field name="mission" placeholder="Enter the Mission Statement here..."/>
                        </page>

                        <!-- PAGE 3: CORE VALUES -->
                        <page string="Core Values" name="page_core_values">
                            <field name="core_value_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="name" string="Core Value" placeholder="e.g. Integrity"/>
                                    <field name="description" placeholder="Description of what this value means..."/>
                                </list>
                            </field>
                        </page>
                        
                        <!-- TAB 1: PILLARS -->
                        <page string="Strategic Pillars" name="page_pillars">
                            <field name="pillar_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="description"/>
                                    <field name="strategic_outcomes" autofocus="autofocus"/>
                                    <field name="key_strategy"/>
                                </list>
                            </field>
                        </page>

                        <!-- TAB 2: GOALS & OBJECTIVES -->
                        <page string="Goals &amp; OKRs" name="page_goals">
                            <field name="goal_ids">
                                <form>
                                    <group>
                                        <field name="name"/>
                                        <field name="strategy_description"/>
                                        <field name="linked_pillar_id" options="{'no_create': True}"/>
                                    </group>
                                    <label for="objective_ids" string="OKRs"/>
                                    <field name="objective_ids">
                                        <list editable="bottom">
                                            <field name="name"/>
                                            <field name="key_results" widget="many2many_tags"/>
                                            <field name="kpi_id" widget="many2many_tags"/>
                                            <field name="description"/>
                                            <field name="key_initiatives"/>
                                        </list>
                                    </field>
                                </form>
                                <list>
                                    <field name="name"/>
                                    <field name="strategy_description"/>
                                </list>
                            </field>
                        </page>

                        <!-- TAB 3: BSC IMPLEMENTATION (5 YEARS) -->
                        <!-- <page string="3. BSC Implementation Matrix" name="page_bsc_impl">
                            <field name="bsc_impl_ids">
                                <list editable="bottom" 
                                    decoration-bf="row_type != 'data'"
                                    decoration-info="row_type == 'perspective'"
                                    decoration-muted="row_type == 'goal'">-->
                                    <!-- CONTROL BUTTONS -->
                                    <!-- <control> -->
                                        <!-- Sets row_type to 'perspective' -->
                                        <!-- <create name="add_perspective" string="Add Perspective" 
                                                context="{'default_row_type': 'perspective'}"/> -->
                                        <!-- Sets row_type to 'goal' -->
                                        <!-- <create name="add_goal" string="Add Strategic Goal" 
                                                context="{'default_row_type': 'goal'}"/> -->
                                        
                                        <!-- Sets row_type to 'data' (default) -->
                                        <!-- <create name="add_line" string="Add KPI Target"/>
                                    </control>

                                    <field name="row_type" column_invisible="1"/>
                                    <field name="document_id" column_invisible="1"/>
                                    <field name="sequence" widget="handle"/> -->

                                    <!-- 1. PERSPECTIVE HEADER COLUMN -->
                                    <!-- Only visible if this row is a Perspective Header -->
                                    <!-- <field name="bsc_perspective" 
                                        string="Perspective"
                                        invisible="row_type != 'perspective'"
                                        required="row_type == 'perspective'"/> -->

                                    <!-- 3. DATA COLUMNS -->
                                    <!-- Hidden if the row is a Perspective or Goal header -->
                                    <!-- <field name="goal_id" invisible="row_type != 'data'"/>
                                    <field name="key_activities" invisible="row_type != 'data'"/>
                                    <field name="kpi_id" invisible="row_type != 'data'"/>
                                    
                                    <field name="baseline" optional="hide" invisible="row_type != 'data'"/>
                                    <field name="target_long_term" string="Final Target" decoration-bf="1" invisible="row_type != 'data'"/> -->
                                    
                                    <!-- Yearly Breakdown -->
                                    <!-- <field name="y1_target" string="Year 1" invisible="row_type != 'data'"/>
                                    <field name="y2_target" string="Year 2" invisible="row_type != 'data'"/>
                                    <field name="y3_target" string="Year 3" invisible="row_type != 'data'"/>
                                    <field name="y4_target" string="Year 4" invisible="row_type != 'data'"/>
                                    <field name="y5_target" string="Year 5" invisible="row_type != 'data'"/>
                                </list>
                            </field>
                        </page> -->

                        <!-- TAB 4: REVENUE FORECAST -->
                        <page string="Revenue Forecast" name="page_revenue_forecast">
                            <field name="revenue_forecast_ids" context="{'default_type': 'revenue'}">
                                <list editable="bottom">
                                    <field name="business_unit_id"/>
                                    <field name="source_of_fund"/>
                                    <field name="kpi_id" string="Metric"/>
                                    
                                    <!-- Added sum attribute for automatic totals -->
                                    <field name="baseline" sum="Total Baseline"/>
                                    <field name="target_long_term" string="5-Yr Target" decoration-bf="1" sum="Total Target"/>
                                    
                                    <field name="y1_value" string="Year 1" sum="Total Y1"/>
                                    <field name="y2_value" string="Year 2" sum="Total Y2"/>
                                    <field name="y3_value" string="Year 3" sum="Total Y3"/>
                                    <field name="y4_value" string="Year 4" sum="Total Y4"/>
                                    <field name="y5_value" string="Year 5" sum="Total Y5"/>
                                    
                                    <field name="type" column_invisible="1"/>
                                </list>
                            </field>
                        </page>

                        <!-- TAB 5: EXPENSE FORECAST -->
                        <page string="Expense Forecast" name="page_expense_forecast">
                            <field name="expense_forecast_ids" context="{'default_type': 'expense'}">
                                <list editable="bottom">
                                    <field name="business_unit_id"/>
                                    <field name="source_of_fund"/>
                                    <field name="kpi_id" string="Metric"/>
                                    
                                    <!-- Added sum attribute for automatic totals -->
                                    <field name="baseline" sum="Total Baseline"/>
                                    <field name="target_long_term" string="5-Yr Target" decoration-bf="1" sum="Total Target"/>
                                    
                                    <field name="y1_value" string="Year 1" sum="Total Y1"/>
                                    <field name="y2_value" string="Year 2" sum="Total Y2"/>
                                    <field name="y3_value" string="Year 3" sum="Total Y3"/>
                                    <field name="y4_value" string="Year 4" sum="Total Y4"/>
                                    <field name="y5_value" string="Year 5" sum="Total Y5"/>
                                    
                                    <field name="type" column_invisible="1"/>
                                </list>
                            </field>
                        </page>

                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_strategy_document" model="ir.actions.act_window">
        <field name="name">Strategic Plans (5-Year)</field>
        <field name="res_model">corporate.strategy.document</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p>Create a new 5-Year Strategic Plan Document.</p>
        </field>
    </record>

</odoo>