<?xml version="1.0" encoding="utf-8"?>
<odoo>

    
    
    <record id="view_budget_type_list" model="ir.ui.view">
        <field name="name">budget.type.list</field>
        <field name="model">corporate.planning.budget.type</field>
        <field name="arch" type="xml">
            <list editable="bottom">
                <field name="name"/>
                <field name="category"/>
            </list>
        </field>
    </record>

    <record id="action_budget_type_config" model="ir.actions.act_window">
        <field name="name">Budget Types</field>
        <field name="res_model">corporate.planning.budget.type</field>
        <field name="view_mode">list</field>
    </record>
    
    <!-- TREE VIEW -->
    <record id="view_budget_general_list" model="ir.ui.view">
        <field name="name">budget.general.list</field>
        <field name="model">corporate.planning.budget.general</field>
        <field name="arch" type="xml">
            <list string="General Budgets">
                <field name="name"/>
                <field name="budget_type_id" widget="badge"/>
                <field name="department_id"/>
                <field name="fiscal_year"/>
                <field name="total_annual_amount" sum="Total Budget" widget="monetary" decoration-bf="1"/>
                <field name="state" widget="badge" decoration-success="state == 'approved'"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="view_budget_general_form" model="ir.ui.view">
        <field name="name">budget.general.form</field>
        <field name="model">corporate.planning.budget.general</field>
        <field name="arch" type="xml">
            <form string="General Budget Plan">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'confirmed'" groups="base.group_user"/>
                    <button name="action_reset_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'" />
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('draft', 'confirmed')"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. 2026 IT Equipment Budget"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="budget_type_id" options="{'no_create': True, 'no_open': True}"/>
                            <field name="budget_category" invisible="1"/> 
                            <field name="company_id" options="{'no_create': True}"/>
                            <field name="analytic_account_id" options="{'no_create': True}"/>
                            <field name="linked_budget_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="department_id"/>
                            <field name="fiscal_year"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Budget Details">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    
                                    <!-- Stock No only for Fixed Assets -->
                                     <field name="stock_no" column_invisible="parent.budget_category != 'asset'"/>
                                    
                                    <field name="description"/>
                                    <field name="product_id" optional="hide"/>
                                    <field name="uom_id" options="{'no_create': True}"/>
                                    
                                    <!-- Price Info -->
                                    <field name="unit_price" widget="monetary"/>
                                    <field name="estimated_price" widget="monetary" optional="show"/>
                                    
                                    <!-- Monthly Info (Hidden for Fixed Assets) -->
                                    <field name="qty_monthly" column_invisible="parent.budget_category == 'asset'"/>
                                    <field name="total_price_monthly" widget="monetary" sum="Monthly Total" 
                                           column_invisible="parent.budget_category == 'asset'"/>
                                    
                                    <!-- Annual Info -->
                                    <field name="qty_annual"/>
                                    <field name="total_price_annual" widget="monetary" sum="Annual Total" decoration-bf="1"/>
                                    
                                    <field name="remark" optional="hide"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_annual_amount" class="oe_subtotal_footer_separator" widget="monetary"/>
                            </group>
                        </page>
                        <page string="Notes &amp; Attachments">
                            <group>
                                <field name="note" placeholder="Add any justification, approval notes, or specific instructions here..."/>
                            </group>
                            <group string="Documents">
                                <field name="attachment_ids" widget="many2many_binary"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_budget_general_planning" model="ir.actions.act_window">
        <field name="name">General &amp; Asset Planning</field>
        <field name="res_model">corporate.planning.budget.general</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Entertainment, Cleaning, or Fixed Asset Budget.
            </p>
        </field>
    </record>

</odoo>