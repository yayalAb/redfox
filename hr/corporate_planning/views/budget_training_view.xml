<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 1. PARENT LIST VIEW -->
    <record id="view_budget_training_list" model="ir.ui.view">
        <field name="name">budget.training.list</field>
        <field name="model">corporate.planning.budget.training</field>
        <field name="arch" type="xml">
            <list string="Training Plans">
                <field name="name"/>
                <field name="department_id"/>
                <field name="fiscal_year"/>
                <field name="analytic_account_id" optional="show"/>
                <field name="total_budget" sum="Total Training Budget" widget="monetary" decoration-bf="1"/>
                <field name="state" widget="badge" 
                       decoration-info="state == 'draft'" 
                       decoration-warning="state == 'confirmed'"
                       decoration-success="state == 'approved'"
                       decoration-muted="state == 'cancelled'"/>
            </list>
        </field>
    </record>

    <!-- 2. FORM VIEW -->
    <record id="view_budget_training_form" model="ir.ui.view">
        <field name="name">budget.training.form</field>
        <field name="model">corporate.planning.budget.training</field>
        <field name="arch" type="xml">
            <form string="Training Budget Plan">
                <header>
                    <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'" />
                    
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'confirmed'" groups="base.group_user"/>
                    
                    <button name="action_reset_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'"/>
                    
                    <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('draft', 'confirmed')" />
                    
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,approved"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1><field name="name" placeholder="e.g. 2018 Training Plan"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="company_id" options="{'no_create': True}"/>
                            <field name="department_id"/>
                            <field name="analytic_account_id" options="{'no_create': True}"/>
                        </group>
                        <group>
                            <field name="fiscal_year"/>
                            <field name="date_from"/>
                            <field name="date_to"/>
                            <field name="linked_budget_id" options="{'no_create': True}"/>
                        </group>
                    </group>
                    
                    <notebook>
                        <page string="Training Programs">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="program_name"/>
                                    <field name="training_content"/>
                                    
                                    <!-- Changed to Many2many tags -->
                                    <field name="participant_ids" widget="many2many_tags" options="{'no_create': True}"/>
                                    
                                    <field name="quantity"/>
                                    <field name="unit_cost"/>
                                    
                                    <!-- Readonly because it is computed -->
                                    <field name="budget_amount" sum="Total" widget="monetary" readonly="1" force_save="1"/>
                                    
                                    <field name="period"/>
                                    <field name="remark"/>
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="total_budget" class="oe_subtotal_footer_separator" widget="monetary"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- 3. ACTION -->
    <record id="action_budget_training_planning" model="ir.actions.act_window">
        <field name="name">Training Planning</field>
        <field name="res_model">corporate.planning.budget.training</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Annual Training Plan.
            </p>
        </field>
    </record>

</odoo>