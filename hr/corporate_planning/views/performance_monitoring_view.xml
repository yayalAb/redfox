<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- 1. FORM VIEW (Data Entry) -->
    <record id="view_performance_review_form" model="ir.ui.view">
        <field name="name">performance.review.form</field>
        <field name="model">corporate.performance.review</field>
        <field name="arch" type="xml">
            <form string="Performance Review">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                    <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'submitted'" groups="base.group_user"/>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="e.g. Q1 2026 Operations Report"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="department_id"/>
                            <field name="fiscal_year"/>
                        </group>
                        <group>
                            <field name="period"/>
                            <field name="date_report"/>
                        </group>
                    </group>

                    <notebook>
                        <!-- <page string="KPI Performance">
                            <field name="kpi_line_ids">
                                <list editable="bottom">
                                    <field name="kpi_id"/>
                                    <field name="weight"/>
                                    <field name="target_value" sum="Total Target"/>
                                    <field name="actual_value" sum="Total Actual"/>
                                    <field name="variance" decoration-danger="variance &lt; 0" decoration-success="variance &gt;= 0"/>
                                    <field name="achievement_percent" widget="progressbar"/>
                                </list>
                            </field>
                        </page> -->

                        <!-- TAB 2: BUDGET UTILIZATION -->
                        <page string="Budget Utilization">
                            <field name="budget_line_ids">
                                <list editable="bottom">
                                    <field name="budget_type"/>
                                    <field name="planned_amount" widget="monetary" sum="Total Planned"/>
                                    <field name="actual_amount" widget="monetary" sum="Total Spent"/>
                                    <field name="balance" widget="monetary"/>
                                    <field name="burn_rate_percent" widget="progressbar"/>
                                </list>
                            </field>
                        </page>

                        <!-- TAB 3: PROJECT STATUS -->
                        <page string="Project Progress">
                            <field name="project_line_ids">
                                <list editable="bottom">
                                    <field name="project_name"/>
                                    <field name="planned_status"/>
                                    <field name="current_status"/>
                                    <field name="completion_percent" widget="progressbar"/>
                                    <field name="status_indicator" widget="badge" 
                                           decoration-success="status_indicator=='on_track'" 
                                           decoration-warning="status_indicator=='at_risk'" 
                                           decoration-danger="status_indicator=='delayed'"/>
                                    <field name="remark"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- 2. TREE VIEW -->
    <record id="view_performance_review_list" model="ir.ui.view">
        <field name="name">performance.review.list</field>
        <field name="model">corporate.performance.review</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="department_id"/>
                <field name="period"/>
                <field name="fiscal_year"/>
                <field name="state" widget="badge" decoration-success="state=='approved'"/>
            </list>
        </field>
    </record>

    <!-- 3. REPORTING: PIVOT VIEW (The Matrix) -->
    <!-- This allows you to drag/drop rows/cols to analyze costs -->
    <record id="view_performance_budget_pivot" model="ir.ui.view">
        <field name="name">performance.budget.pivot</field>
        <field name="model">corporate.performance.budget.line</field>
        <field name="arch" type="xml">
            <pivot string="Budget Performance Analysis">
                <field name="review_id" type="row"/>
                <field name="budget_type" type="col"/>
                <field name="actual_amount" type="measure"/>
                <field name="planned_amount" type="measure"/>
                <field name="burn_rate_percent" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- 4. REPORTING: GRAPH VIEW -->
    <record id="view_performance_kpi_graph" model="ir.ui.view">
        <field name="name">performance.kpi.graph</field>
        <field name="model">corporate.performance.kpi.line</field>
        <field name="arch" type="xml">
            <graph string="KPI Achievement Analysis" type="bar">
                <!-- <field name="kpi_id" type="row"/> -->
                <field name="actual_value" type="measure"/>
                <field name="target_value" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- ACTIONS -->
    <record id="action_performance_review" model="ir.actions.act_window">
        <field name="name">Performance Reviews</field>
        <field name="res_model">corporate.performance.review</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- REPORTING ACTIONS -->
    <record id="action_report_budget_matrix" model="ir.actions.act_window">
        <field name="name">Budget Analysis Matrix</field>
        <field name="res_model">corporate.performance.budget.line</field>
        <field name="view_mode">pivot,graph</field>
    </record>

    <record id="action_report_kpi_matrix" model="ir.actions.act_window">
        <field name="name">KPI Analysis Matrix</field>
        <field name="res_model">corporate.performance.kpi.line</field>
        <field name="view_mode">graph,pivot</field>
    </record>

</odoo>