<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View for the Annual Plan -->
        <record id="view_annual_plan_form" model="ir.ui.view">
            <field name="name">annual.plan.form</field>
            <field name="model">corporate.planning.annual.plan</field>
            <field name="arch" type="xml">
                <form string="Annual Plan">
                    <header>
                        <button name="action_confirm" string="Confirm" type="object" class="oe_highlight" invisible="state != 'draft'"/>
                        <button name="action_approve" string="Approve" type="object" class="oe_highlight" invisible="state != 'confirmed'" groups="base.group_user"/>
                        <button name="action_reset_draft" string="Reset to Draft" type="object" invisible="state != 'cancelled'" />
                        <button name="action_cancel" string="Cancel" type="object" invisible="state not in ('draft', 'confirmed')"/>
                        <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,approved"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <label for="name" class="oe_edit_only"/>
                            <h1><field name="name" placeholder="e.g., FY2026 Marketing Department Plan"/></h1>
                        </div>
                        <group>
                            <group>
                                <field name="department_id"/>
                                <field name="budget_id" options="{'no_create': True}"/>
                                <field name="linked_budget_total" widget="monetary"/>
                                <field name="kpi_category" widget="many2many_tags"/>
                            </group>
                            <group>
                                <field name="start_date"/>
                                <field name="end_date"/>
                                <field name="preparation_date"/>
                                <field name="strategy_type_id" options="{'no_create': True}"/>
                            </group>
                        </group>

                        <notebook>
                            <page string="1. Executive Summary">
                                <field name="executive_summary"/>
                            </page>
                            <page string="2. Alignment with Goal">
                                <field name="alignment_goal"/>
                            </page>
                            <page string="3. Key Pillars and Objectives">
                                <field name="key_pillars"/>
                            </page>
                            
                            <page string="Linked KPIs">                               
                                <field name="kpi_id">
                                    
                                    <list string="Selected KPIs">
                                        <field name="Kpi_category"/>
                                        <field name="name"/>
                                        <field name="weight"/>
                                    </list>
                                </field>
                            </page>
                            <page string="4. Risk and Mitigation">
                                <field name="risk_mitigation_ids" mode="list,form" widget="section_and_note_one2many">
                                    <list editable="bottom">
                                        <control>
                                            <create name="add_line_control" string="Add a Risk"/>
                                            <create name="add_section_control" string="Add a Risk Title (Section)" context="{'default_display_type': 'line_section'}"/>
                                            <create name="add_note_control" string="Add a Note" context="{'default_display_type': 'line_note'}"/>
                                        </control>
                                        
                                        <field name="sequence" widget="handle"/>
                                        <field name="display_type" invisible="1"/>
                                        
                                        <!-- 
                                        1. SECTION TITLE (Name) 
                                        Use 'invisible' (Row level), not 'column_invisible'.
                                        This hides the input box for normal lines, but shows it for Sections.
                                        -->
                                        <field name="name" widget="section_and_note_text" string="Section / Note"
                                            invisible="display_type in ('line_section', 'line_note')"/>
                                        
                                        <!-- 
                                        2. DATA FIELDS (Risk & Mitigation)
                                        Hide these specific cells if the row is a Section or Note.
                                        -->
                                        <field name="risk" string="Risk"
                                            invisible="display_type in ('line_section', 'line_note')"/>

                                        <field name="mitigation" 
                                            invisible="display_type in ('line_section', 'line_note')"/>
                                    </list>
                                </field>
                            </page>
                            <page string="5. Performance Measurement (70%)">
                                <field name="performance_measure_ids" mode="list,form">
                                    <list editable="bottom">
                                        <field name="sequence" widget="handle"/>
                                        <field name="category"/>
                                        <field name="weight"/>
                                        <field name="metric"/>
                                        <field name="remark"/>
                                    </list>
                                </field>
                                <div class="oe_subtotal_footer oe_right">
                                    <!-- Optional: Add a total for the weight column if needed -->
                                </div>
                            </page>
                            <page string="6. Conclusion">
                                <field name="conclusion"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter /> 
                </form>
            </field>
        </record>
        <!-- We also need a Tree (List) View and an Action to open it -->
        <record id="view_annual_plan_list" model="ir.ui.view">
            <field name="name">annual.plan.list</field>
            <field name="model">corporate.planning.annual.plan</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="department_id"/>
                    <field name="start_date"/>
                    <field name="end_date"/>
                    <field name="company_id"/>
                </list>
            </field>
        </record>

        <record id="action_annual_plan" model="ir.actions.act_window">
            <field name="name">Annual Plans</field>
            <field name="res_model">corporate.planning.annual.plan</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create a new Annual Plan to get started.
                </p>
            </field>
        </record>

        <record id="action_strategy_type_config" model="ir.actions.act_window">
            <field name="name">Business Strategy Types</field>
            <field name="res_model">corporate.strategy.type</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu Item
        <menuitem id="menu_corporate_planning_root" name="Corporate Planning"/>
        <menuitem id="menu_annual_plan" name="Annual Plans" parent="menu_corporate_planning_root" action="action_annual_plan"/> -->

    </data>
</odoo>