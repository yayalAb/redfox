<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Client Action -->
    <record id="action_corporate_dashboard_client" model="ir.actions.client">
        <field name="name">Strategic Dashboard</field>
        <field name="tag">corporate_dashboard_tag</field>
    </record>

    <!-- 1. VIEW FOCUS: CORE VALUES -->
    <record id="view_strategy_doc_form_values" model="ir.ui.view">
        <field name="name">strategy.doc.form.values</field>
        <field name="model">corporate.strategy.document</field>
        <field name="inherit_id" ref="corporate_planning.view_strategy_doc_form"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <!-- Target the field inside the Core Values tab and focus it -->
            <xpath expr="//field[@name='core_value_ids']" position="attributes">
                <attribute name="default_focus">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- 2. VIEW FOCUS: PILLARS -->
    <record id="view_strategy_doc_form_pillars" model="ir.ui.view">
        <field name="name">strategy.doc.form.pillars</field>
        <field name="model">corporate.strategy.document</field>
        <field name="inherit_id" ref="corporate_planning.view_strategy_doc_form"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='pillar_ids']" position="attributes">
                <attribute name="default_focus">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- 3. VIEW FOCUS: GOALS -->
    <record id="view_strategy_doc_form_goals" model="ir.ui.view">
        <field name="name">strategy.doc.form.goals</field>
        <field name="model">corporate.strategy.document</field>
        <field name="inherit_id" ref="corporate_planning.view_strategy_doc_form"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <!-- Target the first field in the Goals tab -->
            <xpath expr="//field[@name='goal_ids']" position="attributes">
                <attribute name="default_focus">1</attribute>
            </xpath>
        </field>
    </record>

    <!-- Menu Item -->
    <menuitem id="menu_corporate_dashboard"
              name="Dashboard"
              parent="menu_corporate_planning_root"
              action="action_corporate_dashboard_client"
              sequence="1"/>
</odoo>