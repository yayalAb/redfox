<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================== -->
    <!-- 1. ACTIVITY PERFORMANCE ANALYSIS               -->
    <!-- ============================================== -->
    
    <!-- Graph View -->
    <record id="view_activity_performance_graph" model="ir.ui.view">
        <field name="name">activity.performance.graph</field>
        <field name="model">corporate.performance.activity</field>
        <field name="arch" type="xml">
            <graph string="Activity Analysis" type="bar" sample="1">
                <field name="department_id"/>
                <field name="quarter_plan" type="measure"/>
                <field name="quarter_actual" type="measure"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="view_activity_performance_pivot" model="ir.ui.view">
        <field name="name">activity.performance.pivot</field>
        <field name="model">corporate.performance.activity</field>
        <field name="arch" type="xml">
            <pivot string="Activity Analysis" sample="1">
                <field name="department_id" type="row"/>
                <field name="activity_master_id" type="row"/>
                <field name="quarter" type="col"/>
                <field name="quarter_plan" type="measure"/>
                <field name="quarter_actual" type="measure"/>
                <field name="percent_achieved" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_activity_performance_search" model="ir.ui.view">
        <field name="name">activity.performance.search</field>
        <field name="model">corporate.performance.activity</field>
        <field name="arch" type="xml">
            <search>
                <field name="department_id"/>
                <field name="fiscal_year"/>
                <field name="activity_master_id"/>
                <filter string="My Department" name="my_dept" domain="[('department_id.manager_id.user_id', '=', uid)]"/>
                <filter string="Low Performance (&lt; 50%)" name="low_perf" domain="[('percent_achieved', '&lt;', 50)]"/>
                <group expand="1" string="Group By">
                    <filter string="Department" name="group_dept" context="{'group_by':'department_id'}"/>
                    <filter string="Quarter" name="group_quarter" context="{'group_by':'quarter'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_activity_analysis" model="ir.actions.act_window">
        <field name="name">Activity Analysis</field>
        <field name="res_model">corporate.performance.activity</field>
        <field name="view_mode">graph,pivot</field>
        <field name="context">{'search_default_group_dept': 1}</field>
    </record>


    <!-- ============================================== -->
    <!-- 2. FINANCIAL PERFORMANCE ANALYSIS              -->
    <!-- ============================================== -->

    <record id="view_financial_performance_graph" model="ir.ui.view">
        <field name="name">financial.performance.graph</field>
        <field name="model">corporate.performance.financial</field>
        <field name="arch" type="xml">
            <graph string="Financial Analysis" type="line" sample="1">
                <field name="quarter"/>
                <field name="quarter_plan_amount" type="measure"/>
                <field name="quarter_actual_amount" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_financial_performance_pivot" model="ir.ui.view">
        <field name="name">financial.performance.pivot</field>
        <field name="model">corporate.performance.financial</field>
        <field name="arch" type="xml">
            <pivot string="Financial Analysis" sample="1">
                <field name="category" type="row"/>
                <field name="item_id" type="row"/>
                <field name="fiscal_year" type="col"/>
                <field name="quarter" type="col"/>
                <field name="quarter_plan_amount" type="measure"/>
                <field name="quarter_actual_amount" type="measure"/>
                <field name="variance_amount" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="action_financial_analysis" model="ir.actions.act_window">
        <field name="name">Financial Analysis</field>
        <field name="res_model">corporate.performance.financial</field>
        <field name="view_mode">pivot,graph</field>
    </record>


