        </record>
        <record id="rule_exec_financial_dept" model="ir.rule">
            <field name="name">Execution Financial: Own Department</field>
            <field name="model_id" ref="model_corporate_execution_financial"/>
            <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_planning_user'))]"/>
        </record>
        <record id="rule_exec_capex_dept" model="ir.rule">
            <field name="name">Execution Capex: Own Department</field>
            <field name="model_id" ref="model_corporate_execution_capex"/>
            <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_planning_user'))]"/>
        </record>
        <record id="rule_exec_okr_dept" model="ir.rule">
