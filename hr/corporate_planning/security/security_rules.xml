        </record>

        <record id="rule_manager_all_budgets" model="ir.rule">
            <field name="name">Manager: See All Budgets</field>
            <field name="model_id" ref="model_corporate_planning_budget_hr"/> <!-- Applied to one, repeat for others if Odoo doesn't cascade naturally (it doesn't) -->
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_planning_manager'))]"/>
        </record>
        
        <record id="rule_manager_all_analysis" model="ir.rule">
            <field name="name">Manager: See All Analysis</field>
            <field name="model_id" ref="model_corporate_plan_actual_analysis"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_planning_manager'))]"/>
        </record>

        <record id="rule_manager_all_risks" model="ir.rule">
            <field name="name">Manager: See All Risks</field>
            <field name="model_id" ref="model_corporate_risk_register"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_planning_manager'))]"/>
        </record>

    </data>
</odoo>