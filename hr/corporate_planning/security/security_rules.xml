            <field name="model_id" ref="model_corporate_execution_okr"/>
            <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_planning_user'))]"/>
        </record>
        
        <!-- RISK REGISTER -->
        <record id="rule_risk_register_dept" model="ir.rule">
            <field name="name">Risk: Own Department</field>
            <field name="model_id" ref="model_corporate_risk_register"/>
            <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_planning_user'))]"/>
        </record>

        <!-- 6. REPORTING / ANALYSIS (The SQL View) -->
        <record id="rule_plan_actual_analysis_dept" model="ir.rule">
            <field name="name">Plan vs Actual Analysis: Own Department</field>
            <field name="model_id" ref="model_corporate_plan_actual_analysis"/>
            <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_planning_user'))]"/>
        </record>

        <!-- ======================================================== -->
        <!-- CORPORATE MANAGER RULES (See ALL)                        -->
        <!-- ======================================================== -->
        
        <!-- Helper function: Apply to all relevant models -->
        <record id="rule_manager_all_aop" model="ir.rule">
            <field name="name">Manager: See All AOP</field>
            <field name="model_id" ref="model_corporate_operating_plan"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_planning_manager'))]"/>
        </record>
        
        <record id="rule_manager_all_annual" model="ir.rule">
            <field name="name">Manager: See All Annual Plan</field>
            <field name="model_id" ref="model_corporate_planning_annual_plan"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('group_planning_manager'))]"/>
        </record>

        <record id="rule_manager_all_okr" model="ir.rule">
            <field name="name">Manager: See All OKR</field>
            <field name="model_id" ref="model_corporate_performance_okr"/>
