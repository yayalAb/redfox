<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- ======================================================== -->
        <!-- DOMAIN DEFINITION (Reusable Logic)                       -->
        <!-- ======================================================== -->
        <!-- 
             Logic: Show record IF 
             1. Department is not set (Global) 
             OR 
             2. Department matches User's Department (or is a child department)
        -->
        
        <!-- 1. ANNUAL GENERAL PLAN -->
        <record id="rule_annual_plan_dept" model="ir.rule">
            <field name="name">Annual Plan: Own Department</field>
            <field name="model_id" ref="model_corporate_planning_annual_plan"/>
            <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_planning_user'))]"/>
        </record>

        <!-- 2. OPERATING PLAN (AOP) -->
        <record id="rule_operating_plan_dept" model="ir.rule">
            <field name="name">AOP: Own Department</field>
            <field name="model_id" ref="model_corporate_operating_plan"/>
            <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_planning_user'))]"/>
        </record>

        <!-- 3. OKR / PERFORMANCE -->
        <record id="rule_okr_dept" model="ir.rule">
            <field name="name">OKR: Own Department</field>
            <field name="model_id" ref="model_corporate_performance_okr"/>
            <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_planning_user'))]"/>
        </record>

        <!-- 4. BUDGETS (Applying to all 4 budget models) -->
        <record id="rule_budget_hr_dept" model="ir.rule">
            <field name="name">HR Budget: Own Department</field>
            <field name="model_id" ref="model_corporate_planning_budget_hr"/>
            <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_planning_user'))]"/>
        </record>
        <record id="rule_budget_training_dept" model="ir.rule">
            <field name="name">Training Budget: Own Department</field>
            <field name="model_id" ref="model_corporate_planning_budget_training"/>
            <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_planning_user'))]"/>
        </record>
        <record id="rule_budget_project_dept" model="ir.rule">
            <field name="name">Project Budget: Own Department</field>
            <field name="model_id" ref="model_corporate_planning_budget_project"/>
            <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_planning_user'))]"/>
        </record>
        <record id="rule_budget_general_dept" model="ir.rule">
            <field name="name">General Budget: Own Department</field>
            <field name="model_id" ref="model_corporate_planning_budget_general"/>
            <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.id)]</field>
            <field name="groups" eval="[(4, ref('group_planning_user'))]"/>
        </record>

        <!-- 5. EXECUTION TRACKING (Applying to all 4 actual models) -->
        <record id="rule_exec_activity_dept" model="ir.rule">
            <field name="name">Execution Activity: Own Department</field>
            <field name="model_id" ref="model_corporate_execution_activity"/>
            <field name="domain_force">['|', ('department_id', '=', False), ('department_id', 'child_of', user.employee_id.department_id.id)]</field>
