<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="odoo_corporate_planning.Dashboard" owl="1">
        <div class="o_corporate_dashboard p-4" style="background-color: #f1f4f6; height: 100%; overflow-y: auto;">
            
            <div class="row align-items-center mb-4">
                <div class="col-md-4">
                    <h2 class="text-dark">Strategic Dashboard</h2>
                </div>
                <div class="col-md-8 d-flex justify-content-end gap-2">

                    <select class="form-control shadow-sm border-0" style="width: 200px;" 
                            t-model="state.filterComp" 
                            t-on-change="() => this.onFilterChange('company')">
                        <option value="">All Companies</option>
                        <t t-foreach="state.dashboardData.filters.companies" t-as="comp" t-key="comp.id">
                            <option t-att-value="comp.id"><t t-esc="comp.name"/></option>
                        </t>
                    </select>
                    <select class="form-control" style="width: 200px;" t-model="state.filterDept" t-on-change="() => this.onFilterChange()">
                        <option value="">All Departments</option>
                        <t t-foreach="state.dashboardData.filters.departments" t-as="dept" t-key="dept.id">
                            <option t-att-value="dept.id"><t t-esc="dept.name"/></option>
                        </t>
                    </select>
                    <select class="form-control" style="width: 150px;" t-model="state.filterQuarter" t-on-change="() => this.onFilterChange()">
                        <option value="">All Quarters</option>
                        <option value="q1">Q1</option>
                        <option value="q2">Q2</option>
                        <option value="q3">Q3</option>
                        <option value="q4">Q4</option>
                    </select>
                    <select class="form-control shadow-sm border-0" style="width: 120px;" 
                            t-model="state.filterYear" 
                            t-on-change="() => this.onFilterChange('year')">
                            <option value="all">All Years</option>
                            <t t-foreach="state.dashboardData.filters.available_years" t-as="yr" t-key="yr">
                            <option t-att-value="yr"><t t-esc="yr"/></option>
                        </t>
                    </select>             
                </div>
            </div>

            <h5 class="text-gray-800 mb-3 ml-1">Strategic Identity</h5>
            <div class="row mb-4">
                <!-- Vision -->
                <div class="col-md-6 mb-3">
                    <div class="card dashboard-card border-l-primary h-100">
                        <div class="card-body">
                            <div class="card-category text-primary-custom mb-2"><i class="fa fa-eye"/> Our Vision</div>
                            <!-- Use t-esc for plain text (No XML tags) -->
                            <div style="font-size: 1.1rem; color: #5a5c69; line-height: 1.5;">
                                <t t-esc="state.dashboardData.cards.identity.vision"/>
                            </div>
                        </div>
                    </div>
                </div>
                <!-- Mission -->
                <div class="col-md-6 mb-3">
                    <div class="card dashboard-card border-l-success h-100">
                        <div class="card-body">
                            <div class="card-category text-success-custom mb-2"><i class="fa fa-rocket"/> Our Mission</div>
                            <div style="font-size: 1.1rem; color: #5a5c69; line-height: 1.5;">
                                <t t-esc="state.dashboardData.cards.identity.mission"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Core Values -->
            <h5 class="text-purple-custom mb-3 ml-1">Core Values</h5>
            
            <div class="row mb-4">
                <t t-foreach="state.dashboardData.cards.identity.values" t-as="val" t-key="val.name">
                    <!-- 1. Use col-md-3 to match the width of performance cards -->
                    <div class="col-md-3 mb-3">
                        <!-- 2. Use h-100 to ensure equal height if descriptions vary -->
                        <div class="card dashboard-card border-l-purple h-100" t-att-title="val.desc">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-center">
                                    <div>
                                        <!-- Label (Like "Avg Performance") -->
                                        <div class="card-category text-purple-custom">Core Value</div>
                                        
                                        <!-- Value (Like "50%") -->
                                        <!-- slightly smaller font than numbers to fit text -->
                                        <div class="card-value" style="font-size: 1.2rem; color: #5a5c69;">
                                            <t t-esc="val.name"/>
                                        </div>
                                    </div>
                                    <!-- Icon Background -->
                                    <i class="fa fa-diamond card-icon-bg text-purple-custom"/>
                                </div>
                            </div>
                        </div>
                    </div>
                </t>
            </div>

            <!-- SECTION 2: FINANCIAL OUTLOOK (Restyled) -->
            <h5 class="text-gray-800 mb-3 ml-1">Financial Outlook (<t t-esc="state.filterYear"/>)</h5>
            <div class="row mb-4">
                
                <!-- REVENUE -->
                <div class="col-md-4 mb-3">
                    <div class="card dashboard-card border-l-success h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div class="card-category text-success-custom">Strategic Revenue</div>
                                <i class="fa fa-line-chart text-success-custom fa-2x" style="opacity: 0.2;"/>
                            </div>
                            <div class="card-value mt-2">
                                <t t-esc="formatCurrency(state.dashboardData.cards.strat_rev)"/>
                            </div>
                            <div class="mt-3 small border-top pt-2">
                                <div class="d-flex justify-content-between">
                                    <span class="text-muted">AOP Planned:</span>
                                    <span class="font-weight-bold text-dark"><t t-esc="formatCurrency(state.dashboardData.cards.aop_revenue)"/></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- EXPENSE -->
                <div class="col-md-4 mb-3">
                    <div class="card dashboard-card border-l-danger h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div class="card-category text-danger-custom">Strategic Expense</div>
                                <i class="fa fa-sort-amount-desc text-danger-custom fa-2x" style="opacity: 0.2;"/>
                            </div>
                            <div class="card-value mt-2">
                                <t t-esc="formatCurrency(state.dashboardData.cards.strat_exp)"/>
                            </div>
                            <div class="mt-3 small border-top pt-2">
                                <div class="d-flex justify-content-between">
                                    <span class="text-muted">Cost of Sales (AOP):</span>
                                    <span class="font-weight-bold text-dark"><t t-esc="formatCurrency(state.dashboardData.cards.aop_cos)"/></span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="text-muted">Operational Exp (AOP):</span>
                                    <span class="font-weight-bold text-dark"><t t-esc="formatCurrency(state.dashboardData.cards.aop_opex)"/></span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="text-muted">Capital Exp (AOP):</span>
                                    <span class="font-weight-bold text-dark"><t t-esc="formatCurrency(state.dashboardData.cards.aop_capex)"/></span>
                                </div>
                                <div class="d-flex justify-content-between">
                                    <span class="text-muted">Total Exp (AOP):</span>
                                    <span class="font-weight-bold text-dark">
                                        <t t-esc="formatCurrency(state.dashboardData.cards.aop_cos + state.dashboardData.cards.aop_opex + state.dashboardData.cards.aop_capex)"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- PROFIT -->
                <div class="col-md-4 mb-3">
                    <div class="card dashboard-card border-l-primary h-100">
                        <div class="card-body">
                            <div class="d-flex justify-content-between">
                                <div class="card-category text-primary-custom">Projected Gross Profit</div>
                                <i class="fa fa-pie-chart text-primary-custom fa-2x" style="opacity: 0.2;"/>
                            </div>
                            <div class="card-value mt-2">
                                <t t-esc="formatCurrency(state.dashboardData.cards.strat_profit)"/>
                            </div>
                            <div class="mt-3 small text-muted">
                                Strategic Variance (Rev - Exp)
                            </div>
                        </div>
                    </div>
                </div>
            </div>


            <!-- ROW 2: OPERATIONAL METRICS (The Missing Cards Added Here) -->
            <h5 class="text-gray-800 mb-3 ml-1">Execution Monitoring</h5>
            <div class="row mb-4">
                
                <!-- 1. AVG PERFORMANCE (Blue) -->
                <div class="col-md-3 mb-3">
                    <div class="card dashboard-card border-l-primary" t-on-click="() => this.onCardClick('performance')">
                        <div class="card-body">
                            <div class="card-category text-primary-custom">Avg. Performance</div>
                            <div class="card-value"><t t-esc="state.dashboardData.cards.avg_performance"/>%</div>
                            <i class="fa fa-tachometer card-icon-bg text-primary-custom"/>
                        </div>
                    </div>
                </div>

                <!-- 2. BUDGET UTILIZATION (Green) -->
                <div class="col-md-3 mb-3">
                    <div class="card dashboard-card border-l-success" t-on-click="() => this.onCardClick('finance')">
                        <div class="card-body">
                            <div class="card-category text-success-custom">Budget Utilization</div>
                            
                            <!-- THE LOGIC: Checks if budget exists for filter -->
                            <t t-if="state.dashboardData.cards.has_budget">
                                <div class="card-value">
                                    <t t-esc="state.dashboardData.cards.budget_utilization"/>%
                                </div>
                            </t>
                            <t t-else="">
                                <div style="margin-top: 10px; font-size: 0.9rem; color: #858796; font-weight: bold;">
                                    <i class="fa fa-ban"/> Not Allocated
                                </div>
                                <div style="font-size: 0.75rem; color: #a0a0a0;">
                                    for this selection
                                </div>
                            </t>

                            <i class="fa fa-money card-icon-bg text-success-custom"/>
                        </div>
                    </div>
                </div>

                <!-- 3. HIGH RISKS (Red) -->
                <div class="col-md-3 mb-3">
                    <div class="card dashboard-card border-l-danger" t-on-click="() => this.onCardClick('risk')">
                        <div class="card-body">
                            <div class="card-category text-danger-custom">High Risks</div>
                            <div class="card-value"><t t-esc="state.dashboardData.cards.risk_count"/></div>
                            <i class="fa fa-exclamation-triangle card-icon-bg text-danger-custom"/>
                        </div>
                    </div>
                </div>

                <!-- 4. ACTIVE PROJECTS (Orange) -->
                <div class="col-md-3 mb-3">
                    <div class="card dashboard-card border-l-warning" t-on-click="() => this.onCardClick('project')">
                        <div class="card-body">
                            <div class="card-category text-warning-custom">Active Projects</div>
                            <div class="card-value"><t t-esc="state.dashboardData.cards.active_projects"/></div>
                            <i class="fa fa-tasks card-icon-bg text-warning-custom"/>
                        </div>
                    </div>
                </div>
            </div>

            <PlanVsActualCharts data="state.dashboardData.charts.pva" />

            <!-- SECTION 2: BSC TRENDS (4 Charts) -->
            <!-- <h4 class="mb-3 text-gray-800">BSC Strategic Trends (5-Year Progression)</h4>
            <div class="row">
                <div class="col-md-6 mb-4">
                    <div class="card shadow">
                        <div class="card-header py-2 font-weight-bold">Financial Goals Trend</div>
                        <div class="card-body"><div style="height: 250px;"><canvas t-ref="chart_fin"/></div></div>
                    </div>
                </div>
                <div class="col-md-6 mb-4">
                    <div class="card shadow">
                        <div class="card-header py-2 font-weight-bold">Customer Goals Trend</div>
                        <div class="card-body"><div style="height: 250px;"><canvas t-ref="chart_cust"/></div></div>
                    </div>
                </div>
                <div class="col-md-6 mb-4">
                    <div class="card shadow">
                        <div class="card-header py-2 font-weight-bold">Process Goals Trend</div>
                        <div class="card-body"><div style="height: 250px;"><canvas t-ref="chart_proc"/></div></div>
                    </div>
                </div>
                <div class="col-md-6 mb-4">
                    <div class="card shadow">
                        <div class="card-header py-2 font-weight-bold">Learning Goals Trend</div>
                        <div class="card-body"><div style="height: 250px;"><canvas t-ref="chart_learn"/></div></div>
                    </div>
                </div>
            </div> -->

            <!-- SECTION 3: FINANCIAL FORECAST (3 Charts) -->
            <h4 class="mb-3 text-gray-800">Financial Forecast by Business Unit</h4>
            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="card shadow">
                        <div class="card-header py-2 font-weight-bold text-success">Revenue Forecast</div>
                        <div class="card-body"><div style="height: 250px;"><canvas t-ref="chart_rev"/></div></div>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="card shadow">
                        <div class="card-header py-2 font-weight-bold text-danger">Expense Forecast</div>
                        <div class="card-body"><div style="height: 250px;"><canvas t-ref="chart_exp"/></div></div>
                    </div>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="card shadow">
                        <div class="card-header py-2 font-weight-bold text-primary">Profit Forecast</div>
                        <div class="card-body"><div style="height: 250px;"><canvas t-ref="chart_prof"/></div></div>
                    </div>
                </div>
            </div>

            <!-- Add this inside the Dashboard Template, perhaps below the Cards row -->

            <div class="row mb-4">
                <div class="col-12">
                    <div class="card shadow">
                        <div class="card-header py-3 border-left-info">
                            <h6 class="m-0 font-weight-bold text-primary">Departmental Strategy Adoption</h6>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive">
                                <table class="table table-striped mb-0">
                                    <thead class="bg-light text-dark">
                                        <tr>
                                            <th>Department</th>
                                            <th>Annual Plan</th>
                                            <th>Year</th>
                                            <th>BU's Ongoing Active Strategy</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-if="state.dashboardData.strategy_usage">
                                            <t t-foreach="state.dashboardData.strategy_usage" t-as="row" t-key="row_index">
                                                <tr>
                                                    <td class="font-weight-bold"><t t-esc="row.department"/></td>
                                                    <td><t t-esc="row.plan_name"/></td>
                                                    <td><t t-esc="row.year"/></td>
                                                    <td>
                                                        <span class="badge badge-info px-3 py-2" style="font-size: 0.9em;">
                                                            <t t-esc="row.strategy"/>
                                                        </span>
                                                    </td>
                                                </tr>
                                            </t>
                                        </t>
                                        <!-- Fallback if empty -->
                                        <t t-if="!state.dashboardData.strategy_usage || state.dashboardData.strategy_usage.length === 0">
                                            <tr>
                                                <td colspan="4" class="text-center text-muted p-3">
                                                    No strategies assigned to Annual Plans yet.
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </t>
</templates>