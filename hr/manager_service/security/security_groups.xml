<odoo>
    <record id="group_manager_service_user" model="res.groups">
        <field name="name">Manager Service User</field>
        <field name="category_id" ref="hr_employee_self_service.category_employee_self_service" />
        <field name="implied_ids"
            eval="[(4, ref('base.group_user')), (4, ref('project.group_project_manager')), 
            (4, ref('training_requisition.training_requisition_group_submit')),
            (4, ref('store_request.group_store_request_approve'))]" />
    </record>

    <record id="hr_leave_request_rule" model="ir.rule">
        <field name="name">Leave Requests</field>   
        <field name="model_id" ref="hr_holidays.model_hr_leave" />
        <field name="groups" eval="[(4, ref('group_manager_service_user'))]" />
        <field name="domain_force">[('department_id', 'child_of', user.employee_id.department_id.id)]</field>
    </record>

    <record id="hr_store_request_rule" model="ir.rule">
        <field name="name">store Requests</field>
        <field name="model_id" ref="store_request.model_store_request" />
        <field name="groups" eval="[(4, ref('group_manager_service_user'))]" />
        <field name="domain_force">[('department_id', 'child_of', user.employee_id.department_id.id)]</field>
    </record>

    <record id="hr_job_request_rule" model="ir.rule">
        <field name="name">job Requests</field>
        <field name="model_id" ref="hr_job_requisition.model_hr_job_requisition" />
        <field name="groups" eval="[(4, ref('group_manager_service_user'))]" />
        <field name="domain_force">[('department_id', 'child_of', user.employee_id.department_id.id)]</field>
    </record>

    <record id="hr_kpi_appraisal_rule" model="ir.rule">
        <field name="name">KPI Appraisal</field>
        <field name="model_id" ref="hr_kpi_appraisal.model_appraisal_kpi" />
        <field name="groups" eval="[(4, ref('group_manager_service_user'))]" />
        <field name="domain_force">[('department_id', 'child_of', user.employee_id.department_id.id)]</field>
    </record>

    <record id="hr_payment_request_rule" model="ir.rule">
        <field name="name">Payment Requests</field>
        <field name="model_id" ref="hr_expense.model_hr_expense_sheet" />
        <field name="groups" eval="[(4, ref('group_manager_service_user'))]" />
        <field name="domain_force">[('department_id', 'child_of', user.employee_id.department_id.id)]</field>
    </record>
</odoo>