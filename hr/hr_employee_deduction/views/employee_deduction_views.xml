<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="employee_deduction_view_form" model="ir.ui.view">
        <field name="name">employee.deduction.form</field>
        <field name="model">employee.deduction</field>
        <field name="arch" type="xml">
            <form string="Employee Deduction">
                <header>
                    <button name="action_submit" string="Submit" type="object" class="oe_highlight"
                        invisible="state != 'draft'" />
                    <button
                        name="action_approve" string="Approve" type="object" class="oe_highlight"
                        invisible="state != 'submitted'"
                        groups="hr_employee_deduction.group_employee_deduction_manager" />
                    <button
                        name="action_reject" string="Reject" type="object"
                        invisible="state not in ('submitted', 'approved')"
                        groups="hr_employee_deduction.group_employee_deduction_manager" />
                    <button
                        name="action_reset_to_draft" string="Reset to Draft" type="object"
                        invisible="state not in ('rejected', 'applied')"
                        groups="hr_employee_deduction.group_employee_deduction_manager" />
                
                    <field
                        name="state" widget="statusbar"
                        statusbar_visible="draft,submitted,approved,applied" />
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="state != 'draft'" placeholder="e.g. Mobile Expense for August"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="employee_id" readonly="state != 'draft'" />
                            <field name="company_id" readonly="1" />
                            <field name="deduction_type_id" readonly="state != 'draft'" />
                        </group>
                        <group>
                            <field name="amount" readonly="state != 'draft'" />
                            <field name="date" readonly="state != 'draft'" />
                            <field name="payslip_id" invisible="state != 'applied'" />
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>
    <record id="employee_deduction_view_tree" model="ir.ui.view">
        <field name="name">employee.deduction.list</field>
        <field name="model">employee.deduction</field>
        <field name="arch" type="xml">
            <list string="Employee Deductions">
                <field name="name" />
                <field name="employee_id" />
                <field name="company_id" />
                <field name="deduction_type_id" />
                <field name="amount" />
                <field name="date" />
                <field name="state" widget="badge" decoration-success="state == 'applied'"
                    decoration-info="state == 'approved'" />
            </list>
        </field>
    </record>
    <record id="employee_deduction_view_search" model="ir.ui.view">
    <field name="name">employee.deduction.search</field>
    <field name="model">employee.deduction</field>
    <field name="arch" type="xml">
        <search string="Employee Deductions">

            <!-- Basic filters -->
            <field name="employee_id"/>
            <field name="company_id"/>
            <field name="deduction_type_id"/>
            <field name="state"/>

           <filter string="This Month" name="this_month" domain="[('date', '>=', context_today().strftime('%Y-%m-01 00:00:00'))]"/>
        </search>
    </field>
</record>


    <!-- Action to open the Employee Deduction views -->
    <record id="action_employee_deduction" model="ir.actions.act_window">
        <field name="name">Employee Deductions</field>
        <field name="res_model">employee.deduction</field>
        <field name="view_mode">list,form</field>
            <field name="context">{'search_default_this_month': 1}</field>

    </record>

    <record id="employee_deduction_type_view_tree" model="ir.ui.view">
        <field name="name">employee.deduction.type.list</field>
        <field name="model">employee.deduction.type</field>
        <field name="arch" type="xml">
            <list string="Deduction Types" editable="bottom">
                <field name="name" />
                <field name="code" />
            </list>
        </field>
    </record>

    <record id="action_employee_deduction_type" model="ir.actions.act_window">
        <field name="name">Deduction Types</field>
        <field name="res_model">employee.deduction.type</field>
        <field name="view_mode">list</field>
    </record>

</odoo>