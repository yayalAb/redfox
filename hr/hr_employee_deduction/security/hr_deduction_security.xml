<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="module_category_employee_deduction" model="ir.module.category">
            <field name="name">Employee Deductions</field>
            <field name="description">User access levels for the Employee Deductions module.</field>
            <field name="sequence">18</field>
        </record>

        <record id="group_employee_deduction_user" model="res.groups">
            <field name="name">Deductions: User</field>
            <field name="category_id" ref="module_category_employee_deduction"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_employee_deduction_manager" model="res.groups">
            <field name="name">Deductions: Manager</field>
            <field name="category_id" ref="module_category_employee_deduction"/>
            <field name="implied_ids" eval="[(4, ref('group_employee_deduction_user'))]"/>
        </record>

        <record id="employee_deduction_company_rule" model="ir.rule">
            <field name="name">Employee Deduction Multi-Company Rule</field>
            <field name="model_id" ref="model_employee_deduction"/>
            <field name="global" eval="True"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        </record>

    </data>
</odoo>