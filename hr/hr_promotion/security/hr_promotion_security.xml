<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Promotion Module Category -->
        <record id="module_category_hr_promotion" model="ir.module.category">
            <field name="name">Promotion</field>
            <field name="description">User access levels for promotion flows.</field>
            <field name="sequence">20</field>
        </record>

        <!-- Promotion Groups -->
        <record id="hr_promotion_review_group" model="res.groups">
            <field name="name">Promotion / Review</field>
            <field name="category_id" ref="module_category_hr_promotion"/>
            <field name="comment">Users with this group can review promotion requests.</field>
        </record>

        <record id="hr_promotion_approve_group" model="res.groups">
            <field name="name">Promotion / Approve</field>
            <field name="category_id" ref="module_category_hr_promotion"/>
            <field name="comment">Users with this group can approve promotion requests.</field>
        </record>

        <record id="hr_promotion_reject_group" model="res.groups">
            <field name="name">Promotion / Reject</field>
            <field name="category_id" ref="module_category_hr_promotion"/>
            <field name="comment">Users with this group can reject promotion requests.</field>
        </record>

        <record id="hr_promotion_draft_group" model="res.groups">
            <field name="name">Promotion / Set to Draft</field>
            <field name="category_id" ref="module_category_hr_promotion"/>
            <field name="comment">Users with this group can set promotion requests back to draft.</field>
        </record>

        <record id="hr_promotion_done_group" model="res.groups">
            <field name="name">Promotion / Mark As Done</field>
            <field name="category_id" ref="module_category_hr_promotion"/>
            <field name="comment">Users with this group can mark promotion requests as done.</field>
        </record>
    </data>
</odoo>

