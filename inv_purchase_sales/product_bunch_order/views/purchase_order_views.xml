<odoo>
    <record id="view_purchase_order_form_product_bunch" model="ir.ui.view">
        <field name="name">purchase.order.form.product.bunch</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            
              <xpath expr="//field[@name='tax_calculation_rounding_method']" position="after">
                      <field name="product_bunch_id" string="Product batch"/>
                <field name="bunch_quantity"/>
                </xpath>
            <xpath expr="//sheet//group" position="inside">
              
            </xpath>
        </field>
    </record>

    <record id="view_purchase_order_form_product_bunch_line_flags" model="ir.ui.view">
        <field name="name">purchase.order.form.product.bunch.line.flags</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='order_line']/list" position="inside">
                <field name="is_bunch_line" column_invisible="1"/>
                <field name="bunch_line_id" column_invisible="1"/>
            </xpath>
        </field>
    </record>
</odoo>
