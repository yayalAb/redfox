<odoo>
    <record id="view_product_bunch_order_tree" model="ir.ui.view">
        <field name="name">product.bunch.order.tree</field>
        <field name="model">product.bunch.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="product_id"/>
            </list>
        </field>
    </record>

    <record id="view_product_bunch_order_form" model="ir.ui.view">
        <field name="name">product.bunch.order.form</field>
        <field name="model">product.bunch.order</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="product_id"/>
                    </group>
                    <notebook>
                        <page string="Product Lines">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_product_bunch_order" model="ir.actions.act_window">
        <field name="name">Product Bunch Orders</field>
        <field name="res_model">product.bunch.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_product_bunch_order"
        name="Product Groups"
        parent="purchase.menu_purchase_config"
        action="action_product_bunch_order"
    />
</odoo>
