<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Sequence for Payment Request -->
        <record id="seq_payment_request" model="ir.sequence">
            <field name="name">Payment Request</field>
            <field name="code">payment.request</field>
            <field name="prefix">WWE/</field>
            <field name="padding">6</field>
            <!-- %(y)s adds the current 2-digit year (e.g., 26). 
                 Change to /18 if you want it hardcoded. -->
            <field name="suffix">/%(y)s</field> 
            <field name="number_next">1223</field>
            <field name="number_increment">1</field>
            <field name="company_id" eval="False"/>
        </record>
    </data>
</odoo>