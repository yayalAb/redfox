<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mrp_production_form_view_inherit_agreement" model="ir.ui.view">
        <field name="name">mrp.production.form.inherit.agreement</field>
        <field name="model">mrp.production</field>
        <field name="inherit_id" ref="mrp.mrp_production_form_view"/>
        <field name="arch" type="xml">
            <!-- Add the agreement link near the 'Source' field for context -->
            <xpath expr="//sheet/group/group[@name='group_extra_info']" position="inside">
                <field name="agreement_id" invisible="not is_main"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="Quality Documents" name="quality_documents" invisible="not is_main">
                    <field name="quality_document_ids" widget="many2many_binary" string="Upload Documents"/>
                </page>
            </xpath>
        </field>
    </record>
</odoo>