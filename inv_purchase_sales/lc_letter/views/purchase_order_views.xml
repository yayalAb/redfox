<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_order_form_inherit_lc_letter" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit.lc.letter</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='partner_ref']" position="after">
                <field name="lc_letter_id" options="{'no_create': True}" invisible="purchase_origin != 'foreign'"/>
            </xpath>
        </field>
    </record>
</odoo>
