<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lc_letter_stage_tree" model="ir.ui.view">
        <field name="name">lc.letter.stage.tree</field>
        <field name="model">lc.letter.stage</field>
        <field name="arch" type="xml">
            <list string="LC Stages" editable="bottom">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="fold"/>
            </list>
        </field>
    </record>

    <record id="action_lc_letter_stage" model="ir.actions.act_window">
        <field name="name">LC Stages</field>
        <field name="res_model">lc.letter.stage</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_lc_letter_stage"
        name="LC Stages"
        parent="purchase.menu_purchase_config"
        action="action_lc_letter_stage"
        sequence="50"/>
</odoo>
