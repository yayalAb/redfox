<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_lc_letter_payment_request_form" model="ir.ui.view">
        <field name="name">lc.letter.payment.request.form</field>
        <field name="model">lc.letter.payment.request</field>
        <field name="arch" type="xml">
            <form string="Payment Request">
                <group>
                    <group>
                        <field name="lc_letter_id" invisible="1"/>
                        <field name="partner_id"/>
                        <field name="product_id" options="{'no_create': True}"/>
                        <field name="amount"/>
                        <field name="currency_id" invisible="1"/>
                    </group>
                    <group>
                        <field name="note"/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                    </group>
                </group>
                <footer>
                    <button name="action_confirm" type="object" string="Submit" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
</odoo>
