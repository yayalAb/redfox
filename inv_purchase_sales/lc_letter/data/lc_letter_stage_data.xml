        <record id="stage_lc_draft" model="lc.letter.stage">
            <field name="name">Draft</field>
            <field name="sequence">10</field>
            <field name="fold">False</field>
        </record>
        <record id="stage_lc_submitted" model="lc.letter.stage">
            <field name="name">Submitted</field>
            <field name="sequence">20</field>
            <field name="fold">False</field>
        </record>
        <record id="stage_lc_opened" model="lc.letter.stage">
            <field name="name">Opened</field>
            <field name="sequence">30</field>
            <field name="fold">False</field>
        </record>
        <record id="stage_lc_cancelled" model="lc.letter.stage">
            <field name="name">Cancelled</field>
            <field name="sequence">40</field>
            <field name="fold">True</field>
        </record>
        <record id="stage_lc_expired" model="lc.letter.stage">
            <field name="name">Expired</field>
            <field name="sequence">50</field>
            <field name="fold">True</field>
        </record>
