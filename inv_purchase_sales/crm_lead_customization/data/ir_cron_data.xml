<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="ir_cron_fetch_facebook_feed" model="ir.cron">
        <field name="name">Social Media: Fetch Facebook Feed</field>
        <field name="model_id" ref="model_crm_facebook_post"/> 
        <field name="state">code</field>
        <field name="code">model.fetch_facebook_feed()</field>
        <field name="interval_number">30</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>
</odoo>