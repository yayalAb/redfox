<odoo>
    <data>
        <!-- 1. FORM VIEW CUSTOMIZATION                 -->
       
        <record id="crm_lead_view_form_custom" model="ir.ui.view">
            <field name="name">crm.lead.form.custom</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_lead_view_form"/>
            <field name="arch" type="xml">
                <!-- Add Fields -->
                <xpath expr="//field[@name='tag_ids']" position="after">
                    <field name="source"/>
                    <!-- options='no_create' prevents regular users from typing junk data -->
                    <field name="sector_id" options="{'no_create': True, 'no_open': True}"/>
                    <field name="industry_id" 
                           options="{'no_create': True, 'no_open': True}"
                           context="{'default_sector_id': sector_id}"/>
                </xpath>

                <!-- Add Agreement Smart Button -->
                <xpath expr="//div[@name='button_box']" position="inside">
                    <button name="action_view_agreements" type="object" class="oe_stat_button" icon="fa-file-text-o">
                        <field string="Agreements" name="agreement_count" widget="statinfo"/>
                    </button>
                </xpath>

                <!-- Add Header Button -->
                <xpath expr="//header" position="inside">
                    <button name="action_create_new_agreement" string="Create Contract Agre." type="object" class="oe_highlight" invisible="not partner_id"/>
                </xpath>
            </field>
        </record>
        

        <!-- 2. SEARCH VIEW CUSTOMIZATION               -->
        <record id="crm_lead_view_search_custom" model="ir.ui.view">
            <field name="name">crm.lead.search.custom</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.view_crm_case_leads_filter"/>
            <field name="arch" type="xml">
                <xpath expr="//group" position="inside">
                    <filter string="Sector" name="groupby_sector" context="{'group_by': 'sector_id'}"/>
                    <filter string="Industry" name="groupby_industry" context="{'group_by': 'industry_id'}"/>
                </xpath>
            </field>
        </record>

        <!-- 3. LIST VIEW CUSTOMIZATION     -->
        
        <!-- Part A: This adds columns to your PIPELINE List (Opportunities) -->
        <record id="crm_lead_view_tree_oppor_custom" model="ir.ui.view">
            <field name="name">crm.lead.tree.oppor.custom</field>
            <field name="model">crm.lead</field>
            <field name="inherit_id" ref="crm.crm_case_tree_view_oppor"/>
            <field name="arch" type="xml">
                <!-- We insert the new columns before the Email column -->
                <xpath expr="//field[@name='email_from']" position="before">
                    <field name="sector_id" optional="show"/>
                    <field name="industry_id" optional="show"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>