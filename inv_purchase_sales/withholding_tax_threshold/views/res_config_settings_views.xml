<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="res_config_settings_view_form_inherit_withholding_threshold" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.withholding.threshold</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="account.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='default_taxes_setting_container']" position="after">
                <block title="Withholding Tax" name="withholding_tax_threshold">
                    <setting string="Withholding Tax Threshold" id="withholding_tax_threshold"
                            help="Apply withholding tax only when document total (before tax) exceeds this amount. Leave at 0 to always apply.">
                        <div class="content-group">
                            <div class="row mt16">
                                <label for="withholding_tax_threshold"/>
                                <field name="withholding_tax_threshold" class="oe_inline"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>
</odoo>
