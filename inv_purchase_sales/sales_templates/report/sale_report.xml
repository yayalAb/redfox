                                            <span
                                                style="border-bottom: 1px solid black; width: 150px; display: inline-block;"></span>
                                        </div>
                                    </div>
                                </div>

                                <div class="row" style="margin-top: 15px;">
                                    <div class="col-8 d-flex align-items-end">
                                        <strong style="white-space: nowrap;">Stamp</strong>
                                        <div
