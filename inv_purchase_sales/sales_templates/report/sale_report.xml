                                            t-as="bank">
                                            <li style="margin-bottom: 10px;">
                                                <t t-esc="bank.bank_id.name" /> Account no:- <span
                                                    t-esc="bank.acc_number" />
                                            </li>
                                        </t>
                                    </ul> -->
                                    <ul style="list-style-type: square; padding-left: 20px; margin-top: 5px;">
                                        <t t-foreach="doc.company_id.partner_id.bank_ids" t-as="bank">
                                            <li style="margin-bottom: 10px;">
                                                <t t-esc="bank.bank_id.name" /> Account no:- <span t-esc="bank.acc_number" />
                                            </li>
                                        </t>
                                    </ul>
                                </div>
                            </div>
                        </t>
                       <t t-if="doc.state == 'sale'">
                            <t t-set="doc" t-value="doc.with_context(lang=doc.partner_id.lang)" />
                            <t t-set="doc_title" t-value="'SALES ORDER FORM'" />
                            <t t-set="doc_number" t-value="'OF/WW/MD/007'" />
                            <t t-set="issue_number" t-value="'1'" />

