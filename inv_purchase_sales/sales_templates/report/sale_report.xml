                                    </div>
                                </div>
                            </div>

                            <!-- CUSTOMER INFO ROW 2 (PO & TIN) -->
                            <div class="row mb-1">
                                <div class="col-2">
                                    <strong>የግዥ ማዘዣ ቁጥር<br />Purchase Order Number</strong>
