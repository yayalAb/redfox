                            <t t-set="doc_title" t-value="'Sales Order'" />
                            <t t-set="doc_number" t-value="doc.name" />
                            <t t-set="issue_number" t-value="'1'" />

                            <div class="row mb-2">
                                <div class='col-9'></div>
                                <div class="col-1">
                                    <strong>Date</strong>: </div>
                                <div class='col-2'>
