                                </div>
                                <div class='col-2'>
                                    <div style="border-bottom: 1px solid black; min-height: 20px;">
                                        <span t-field="doc.name" style="padding-left: 5px;" />
                                    </div>
                                </div>
                            </div>

                            <!-- CUSTOMER INFO ROW 1 -->
                            <div class="row mb-2 mt-2">
                                <div class="col-2">
                                    <strong>የደንበኛ ስም:-<br />Customer Name:</strong>
