<odoo>
    <template id="report_saleorder_document_inherited" inherit_id="sale.report_saleorder_document">
        <xpath expr="//t[@t-call='web.external_layout']" position="replace">
            <t t-call="web.html_container">
                <t t-call="web.external_layout">
                    <div class="page"
                        style="font-family: 'Noto Sans Ethiopic', 'Times New Roman', serif; font-size: 14px; padding: 0 30px; position: relative; min-height: 850px;">

                        <div class="oe_structure" />


                        <t t-if="doc.state in ['draft', 'quotation_submit', 'quotation_review', 'quotation_approve', 'quotation_refuse', 'order_submit', 'order_review', 'sent', 'cancel']">
