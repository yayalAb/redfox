                                    <div style="flex-grow: 1; border-bottom: 1px solid black; margin-right: 8px; min-height: 20px;">
                                        <span t-field="doc.contract_ref" style="padding-left: 15px;" />
                                    </div>
                                </div>
                            </div>

                            <!-- TABLE START -->
                            <table class="table table-sm table-bordered mt-3"
                                style="border: 1px solid black; border-collapse: collapse; width: 100%;">
                                <thead style="background-color: #f2f2f2; display: table-header-group;">
                                    <tr style="font-weight: bold;">
                                        <td style="border: 1px solid black; padding: 2px; text-align:center;">ተ.ቁ<br />S.No</td>
