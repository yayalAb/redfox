<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="module_category_invoice_bill_approver" model="ir.module.category">
        <field name="name">Invoice/Bill Approver</field>
        <field name="description">User access levels for invoice and bill approval actions.</field>
        <field name="sequence">20</field>
    </record>

    <record id="module_category_payment_approver" model="ir.module.category">
        <field name="name">Payment Approver</field>
        <field name="description">User access levels for payment-related actions.</field>
        <field name="sequence">21</field>
    </record>

    <!-- Post/Confirm Button Group -->
    <record id="group_invoice_bill_post" model="res.groups">
        <field name="name">Post/Confirm Invoice/Bill</field>
        <field name="category_id" ref="module_category_invoice_bill_approver" />
        <field name="comment">User can post or confirm invoices and bills.</field>
    </record>

    <!-- Send Button Group -->
    <record id="group_invoice_bill_send" model="res.groups">
