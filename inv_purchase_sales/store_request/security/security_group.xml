<odoo>
    <record id="module_category_store_request" model="ir.module.category">
        <field name="name">Store Request</field>
        <field name="description">User access levels for store request flows.</field>
        <field name="sequence">19</field>
    </record>

    <record id="store_request_verify" model="res.groups">
        <field name="name">Store Request Verify</field>
        <field name="category_id" ref="module_category_store_request" />
    </record>
    
    <record id="group_store_request_approve" model="res.groups">
        <field name="name">store request approve</field>
        <field name="category_id" ref="module_category_store_request" />
        <field name="comment">Only users in this group can approve store requests.</field>
    </record>

    <record id="group_store_request_issue" model="res.groups">
        <field name="name">store request issue</field>
        <field name="category_id" ref="module_category_store_request" />
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]" />
        <field name="comment">Only users in this group can issue items.</field>
    </record>

    <record id="group_purchase_request_create" model="res.groups">
        <field name="name">Purchase request Create</field>
        <field name="category_id" ref="module_category_store_request" />
        <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]" />
        <field name="comment">Only users in this group can create purchase requests.</field>
    </record>


    <record id="hr_store_request_manager_rule" model="ir.rule">
        <field name="name">Approved Store Requests</field>
        <field name="model_id" ref="model_store_request" />
        <field name="groups" eval="[(4, ref('stock.group_stock_manager'))]" />
        <field name="domain_force">[('state', 'not in', ['draft', 'submitted'])]</field>
        <field name="perm_read" eval="1" />
        <field name="perm_write" eval="1" />
        <field name="perm_create" eval="1" />
        <field name="perm_unlink" eval="1" />
    </record>
</odoo>