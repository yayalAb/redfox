<odoo>
    <record id="module_category_payment_request" model="ir.module.category">
        <field name="name">Payment Request</field>
        <field name="description">User access levels for payment request approval workflow.</field>
        <field name="sequence">20</field>
    </record>

   <record id="group_payment_request_submit" model="res.groups">
        <field name="name">submit</field>
        <field name="category_id" ref="module_category_payment_request" />
    </record>

    <record id="group_payment_request_verifier" model="res.groups">
        <field name="name">Verify</field>
        <field name="category_id" ref="module_category_payment_request" />
    </record>

   <record id="group_payment_request_rest_to_draft" model="res.groups">
        <field name="name">Reset To Draft</field>
        <field name="category_id" ref="module_category_payment_request" />
    </record>

   <record id="group_payment_request_refuse" model="res.groups">
        <field name="name">Refuse</field>
        <field name="category_id" ref="module_category_payment_request" />
    </record>

   <record id="group_payment_request_approve" model="res.groups">
        <field name="name">Approve</field>
        <field name="category_id" ref="module_category_payment_request" />
    </record>

   <record id="group_payment_request_print_report" model="res.groups">
        <field name="name">Print</field>
        <field name="category_id" ref="module_category_payment_request" />
    </record>

   <record id="group_payment_request_post" model="res.groups">
        <field name="name">Post</field>
        <field name="category_id" ref="module_category_payment_request" />
    </record>

   <record id="group_payment_request_process" model="res.groups">
        <field name="name">Process</field>
        <field name="category_id" ref="module_category_payment_request" />
    </record>

    <record id="group_purchase_approver_low" model="res.groups">
        <field name="name">Authorize (Amount &lt;= 500,000)</field>
        <field name="category_id" ref="module_category_payment_request" />
    </record>

    <record id="group_purchase_approver_high" model="res.groups">
        <field name="name">Authorize (Amount &gt; 500,000)</field>
        <field name="category_id" ref="module_category_payment_request" />
    </record>
</odoo>
