<odoo>
    <record id="sequence_purchase_request_local" model="ir.sequence">
        <field name="name">Local Purchase Request</field>
        <field name="code">purchase.request.local</field>
        <field name="prefix"></field>
        <field name="suffix">-%(y)s</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>

    <record id="sequence_purchase_request_foreign" model="ir.sequence">
        <field name="name">Foreign Purchase Request</field>
        <field name="code">purchase.request.foreign</field>
        <field name="prefix"></field>
        <field name="suffix">-%(y)s</field>
        <field name="padding">5</field>
        <field name="company_id" eval="False"/>
    </record>
</odoo>