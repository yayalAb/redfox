<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_rfp_split_wizard_line_list" model="ir.ui.view">
        <field name="name">rfp.split.wizard.line.list</field>
        <field name="model">rfp.split.wizard.line</field>
        <field name="arch" type="xml">
            <list editable="bottom" string="Products">
                <field name="product_line_id" column_invisible="1"/>
                <field name="product_name" readonly="1"/>
                <field name="description" readonly="1"/>
                <field name="product_qty" string="Original Qty" readonly="1"/>
                <field name="product_uom" readonly="1"/>
                <field name="split_qty" string="Qty to Split" required="1"/>
            </list>
        </field>
    </record>

    <record id="view_rfp_split_wizard_form" model="ir.ui.view">
        <field name="name">rfp.split.wizard.form</field>
        <field name="model">rfp.split.wizard</field>
        <field name="arch" type="xml">
            <form string="Split RFP">
                <group>
                    <field name="rfp_id" readonly="1"/>
                    <field name="re_evaluation" />
                    <field name="evaluation_reason" invisible="not re_evaluation" />
                </group>
                <notebook>
                    <page string="Select Products to Split">
                        <field name="product_line_ids" nolabel="1"/>
                        <div class="alert alert-info" role="alert">
                            <p><strong>Instructions:</strong></p>
                            <ul>
                                <li>Enter the quantity to split for each product you want to move to a new RFP.</li>
                                <li>The remaining quantity will stay in the original RFP.</li>
                                <li>Products with split quantity = 0 will remain unchanged in the original RFP.</li>
                            </ul>
                        </div>
                    </page>
                </notebook>
                <footer>
                    <button string="Split RFP" name="action_split_rfp" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_rfp_split_wizard" model="ir.actions.act_window">
        <field name="name">Split RFP</field>
        <field name="res_model">rfp.split.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
