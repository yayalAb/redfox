<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- WIZARD VIEW FOR REJECTION --> 
    <record id="view_tender_refuse_wizard_form" model="ir.ui.view">
        <field name="name">tender.refuse.wizard.form</field>
        <field name="model">tender.refuse.wizard</field>
        <field name="arch" type="xml">
            <form string="Provide Feedback">
                <group>
                    <field name="tender_id" invisible="1"/>
                    <field name="refuse_type" invisible="1"/>
                    <field name="refuse_reason" placeholder="Explain why..."/>
                </group>
                <footer>
                    <button name="action_confirm_refuse" string="Confirm" type="object" class="btn-danger"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>
    <record id="view_tender_request_kanban" model="ir.ui.view">
        <field name="name">tender.request.kanban</field>
        <field name="model">tender.request</field>
        <field name="arch" type="xml">
            <kanban default_group_by="stage_id"
                class="o_kanban_small_column"
                sample="1"
                quick_create="false">

                <field name="stage_id" />
                <field name="id" />
                <field name="name" />
                <field name="title" />
                <field name="customer_id" />
                <field name="tender_value" />
                <field name="currency_id" />
                <field name="state" />
                <field name="submission_deadline" />
                <field name="create_uid" />
                <field name="activity_ids" />
                <field name="activity_state" />

                <progressbar field="activity_state"
                    colors='{"planned": "success", "today": "warning", "overdue": "danger"}'
                    sum_field="tender_value"
                    help="This bar allows to filter the tenders based on scheduled activities." />

                <templates>
                    <t t-name="menu">
                        <t t-if="widget.editable">
                            <a role="menuitem" type="open" class="dropdown-item">Edit</a>
                        </t>
                        <t t-if="widget.deletable">
                            <a role="menuitem" type="delete" class="dropdown-item">Delete</a>
                        </t>
                    </t>

                    <t t-name="card">
                        <widget name="web_ribbon" title="Lost" bg_color="text-bg-danger" invisible="state != 'lost'" />
                        <widget name="web_ribbon" title="Won" bg_color="text-bg-success" invisible="state != 'won'" />

                        <div class="fw-bold fs-5">
                            <field name="title" />
                        </div>
                        <div class="text-muted small mb-1">
                            <field name="name" />
                        </div>

                        <div t-if="record.tender_value.raw_value">
                            <field name="tender_value" widget="monetary" options="{'currency_field': 'currency_id'}" />
                        </div>

                        <div class="text-truncate">
                            <span t-if="record.customer_id.value">
                                <i class="fa fa-building-o me-1" title="Customer" />
                                <field name="customer_id" />
                            </span>
                        </div>

                        <div class="text-muted small mt-1" t-if="record.submission_deadline.raw_value">
                            <i class="fa fa-clock-o me-1" title="Submission Deadline" />
                            <field name="submission_deadline" widget="remaining_days" />
                        </div>

                        <footer class="pt-1">
                            <div class="d-flex mt-auto align-items-center">
                                <field name="activity_ids" widget="kanban_activity" />
                            </div>
                            <field name="create_uid" widget="many2one_avatar_user" class="ms-auto" />
                        </footer>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_tender_request_form" model="ir.ui.view">
        <field name="name">tender.request.form</field>
        <field name="model">tender.request</field>
        <field name="arch" type="xml">
            <form string="Tender Request">
                <header>
                    
                    <!-- 1. User submits for manager review -->
                    <button name="action_submit_internal" string="Submit for Review" type="object" class="oe_highlight"
                        invisible="state != 'draft'" groups="company_tender_management.group_tender_submit"/>
                        
                    
                    <!-- 2. Manager reviews: Bid Fits OR Reject -->
                    <button name="action_bid_fit" string="Bid Fits" type="object" class="oe_highlight"
                        invisible="state != 'review'" groups="company_tender_management.group_tender_review"/>
                        
                    <button name="action_bid_reject" string="Reject Bid" type="object" class="btn-danger"
                        invisible="state != 'review'" groups="company_tender_management.group_tender_review"/>

                    <!-- STEP 3: Tech Prep -> Tech Review -->
                    <button name="action_submit_tech_docs" string="Submit Tech Docs" type="object" class="oe_highlight"
                        invisible="state != 'tech_prep'" groups="company_tender_management.group_tender_doc_submit"/>

                    <!-- STEP 4: Tech Review -> Submit to Client / Return -->
                    <button name="action_approve_tech_docs" string="Submit to Client" type="object" class="btn-success"
                        invisible="state != 'tech_review'" groups="company_tender_management.group_tender_client_submission"/>
                    <button name="action_refuse_tech_docs" string="Return for Revision" type="object" class="btn-warning"
                        invisible="state != 'tech_review'" groups="company_tender_management.group_tender_doc_review"/>

                    <!-- 5. Mark as Submitted to Client (Optional visual step) -->
                    <button name="action_submit_to_client" string="Mark as Submitted to Client" type="object"
                        invisible="state != 'submission'" groups="company_tender_management.group_tender_client_submission"/>

                    <!-- 6. Final Outcomes -->
                    <button name="action_win" type="object" string="Mark as Won" class="btn-success"
                        invisible="state != 'submission'" groups="company_tender_management.group_tender_win"/>
                        
                    <button name="action_lose" type="object" string="Mark as Lost" class="btn-danger"
                        invisible="state != 'submission'" groups="company_tender_management.group_tender_lose"/>

                    <!-- 7. Reset -->
                    <button name="action_reset_draft" string="Reset to Draft" type="object"
                        invisible="state not in ['cancelled', 'lost', 'rejected']" 
                        groups="company_tender_management.group_tender_reset"/>

                    <!-- Document Generation Buttons -->
                    <button name="action_create_agreement" type="object" string="Create Agreement"
                        class="oe_highlight" invisible="state != 'won'" />
                    <button name="action_create_warranty_letter" type="object" string="Create Warranty Letter"
                        class="oe_highlight" invisible="state != 'won'" />
                    <button name="action_create_power_of_attorney" type="object" string="Create Power of Attorney"
                        class="oe_highlight" invisible="state not in ['review', 'submission']" />
                    <button name="action_create_bid_bond" type="object" string="Create Bid Bond"
                        class="oe_highlight" invisible="state not in ['review', 'submission']" />

                    <!-- Strict Statusbar replacing Clickable Stage -->
                    <field name="state" widget="statusbar" statusbar_visible="draft,review,tech_prep,tech_review,submission,won"/>
                </header>
                <sheet>
                    <!-- Ribbons -->
                    <widget name="web_ribbon" title="Lost" bg_color="text-bg-danger" invisible="state != 'lost'" />
                    <widget name="web_ribbon" title="Rejected" bg_color="text-bg-secondary" invisible="state != 'rejected'" />
                    <widget name="web_ribbon" title="Won" bg_color="text-bg-success" invisible="state != 'won'" />

                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_agreements" type="object" class="oe_stat_button"
                            icon="fa-file-text-o" invisible="agreement_count == 0">
                            <field name="agreement_count" widget="statinfo" string="Agreements" />
                        </button>

                        <button name="action_view_bid_bonds" type="object" class="oe_stat_button"
                            icon="fa-money" invisible="bid_bond_count == 0">
                            <field name="bid_bond_count" widget="statinfo" string="Bid Bonds" />
                        </button>

                        <button name="action_view_warranty_letters" type="object" class="oe_stat_button"
                            icon="fa-shield" invisible="warranty_count == 0">
                            <field name="warranty_count" widget="statinfo" string="Warranty Letters" />
                        </button>

                        <button name="action_view_power_of_attorneys" type="object" class="oe_stat_button"
                            icon="fa-file-signature" invisible="power_attorney_count == 0">
                            <field name="power_attorney_count" widget="statinfo" string="Power of Attorneys" />
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1" />
                        </h1>
                    </div>
                    <group>
                        <group>
                            <!-- Fields locked down after finishing -->
                             <field name="title" readonly="state in ['won', 'lost']"/>
                            <field name="name" readonly="0"/>
                            <field name="customer_id" readonly="state in ['won', 'lost']"/>
                            <field name="responsible_id" widget="many2one_avatar_user" 
                                   readonly="state in ['won', 'lost', 'rejected']"
                                   required="state == 'review'"/>
                            <field name="goods_description" readonly="state in ['won', 'lost']"/>
                            <field name="winning_price" invisible="state != 'lost'" />
                            
                            <!-- Kept stage_id invisible to sync kanban but hide from user -->
                            <field name="stage_id" invisible="1"/>
                        </group>
                        <group>
                            <field name="submission_deadline" readonly="state in ['won', 'lost']"/>
                            <field name="bid_doc_cost" readonly="state in ['won', 'lost']"/>
                            <field name="supplier_id" readonly="state in ['won', 'lost']"/>
                            <field name="company_id" groups="base.group_multi_company" /> 
                        </group>

                         <group invisible="state != 'rejected'">
                            <field name="rejection_reason" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Bill of Quantity" name="tender_lines">
                            <field name="tender_line_ids" readonly="state in ['won', 'lost']">
                                <list editable="bottom">
                                    <field name="product_id" />
                                    <field name="description" />
                                    <field name="quantity" />
                                    <field name="unit_price" invisible="parent.state not in ['submission', 'won', 'lost']" />
                                    <field name="subtotal" sum="Total" invisible="parent.state not in ['submission', 'won', 'lost']" />
                                </list>
                            </field>
                            <group class="oe_subtotal_footer oe_right">
                                <field name="tender_value" class="oe_subtotal_footer_separator" />
                            </group>
                        </page>
                        <page string="LegalDocuments" name="documents">
                            <group string="Submission Files">
                                <!-- <field name="tender_document_filename" invisible="1" /> -->
                                <field name="tender_document_ids" widget="many2many_binary" 
                                       string="Tender Request Documents " />
                            </group>

                            <group string="Company Legal Documents">
                                <p class="text-muted" colspan="2">
                                    The documents below are automatically linked from your Company Profile.
                                </p>
                                <group>
                                    <field name="co_business_license" widget="binary" />
                                    <field name="co_commercial_reg" widget="binary" />
                                    <field name="co_tin_cert" widget="binary" />
                                    <field name="co_vat_cert" widget="binary" />
                                    <field name="co_experience_letters" widget="many2many_binary" />
                                </group>
                                <group>
                                    <field name="co_tax_clearance" widget="binary" />
                                    <field name="co_egp_reg" widget="binary" />
                                    <field name="co_audit_report" widget="binary" />
                                    <field name="co_financial_standing" widget="binary" />
                                </group>
                            </group>
                        </page>
                        <!--  Technical Documents -->
                        <page string="Technical Documents" name="technical_docs">
                            <field name="technical_document_ids" widget="many2many_binary" 
                                       readonly="state in ['won', 'lost', 'rejected']"
                                       string="Upload Technical Documents"/>
                        </page>

                        <page string="Bid Requirements" name="checklists">
                            <separator string="Requirements (Text Description)"/>
                            <field name="requirements_text" 
                                   placeholder="Type or paste the bid requirements here..." 
                                   readonly="state in ['won', 'lost']"/>
                            
                            <separator string="Requirements (Checklist)"/>
                            <field name="checklist_ids" readonly="state in ['won', 'lost']">
                                <list editable="bottom">
                                    <field name="name" />
                                    <field name="description" />
                                    <field name="is_mandatory" />
                                    <field name="is_done" />
                                </list>
                            </field>
                        </page>
                        <page string="Outcome Details" name="outcome_details"
                            invisible="state not in ['lost']">
                            <group>
                                <field name="lost_reason_id" readonly="1"/>
                                <field name="lost_reason_notes" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter />
            </form>
        </field>
    </record>

    <record id="view_tender_request_list" model="ir.ui.view">
        <field name="name">tender.request.list</field>
        <field name="model">tender.request</field>
        <field name="arch" type="xml">
            <list string="Tender Requests" decoration-success="state == 'won'"
                decoration-danger="state == 'lost'" decoration-muted="state == 'cancelled'">
                <field name="name" />
                <field name="title" />
                <field name="customer_id" />
                <field name="submission_deadline" />
                <field name="tender_value" />
                <field name="state" />
            </list>
        </field>
    </record>

    <record id="view_tender_request_search" model="ir.ui.view">
        <field name="name">tender.request.search</field>
        <field name="model">tender.request</field>
        <field name="arch" type="xml">
            <search string="Search Tenders">
                <field name="name" />
                <field name="title" />
                <field name="customer_id" />
                <filter string="My Tenders" name="my_tenders" domain="[('create_uid', '=', uid)]" />
                <filter string="Won" name="won" domain="[('state', '=', 'won')]" />
                <filter string="Lost" name="lost" domain="[('state', '=', 'lost')]" />
                <filter string="Active Tenders" name="active_tenders"
                    domain="[('state', 'not in', ['won', 'lost', 'cancelled'])]" />
                <group expand="0" string="Group By">
                    <filter string="Stage" name="group_stage" context="{'group_by': 'stage_id'}" />
                    <filter string="Customer" name="group_customer" context="{'group_by': 'customer_id'}" />
                </group>
            </search>
        </field>
    </record>

    <record id="action_tender_request" model="ir.actions.act_window">
        <field name="name">Tender Participation</field>
        <field name="res_model">tender.request</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem id="menu_tender_root" name="Tenders" parent="sale.sale_menu_root" sequence="10" />
    <menuitem id="menu_tender_request" name="Tender Participation" parent="menu_tender_root"
        action="action_tender_request" sequence="1" />

    <record id="view_tender_request_pivot" model="ir.ui.view">
        <field name="name">tender.request.pivot</field>
        <field name="model">tender.request</field>
        <field name="arch" type="xml">
            <pivot string="Tender Analysis">
                <field name="customer_id" type="row" />
                <field name="state" type="col" />
                <field name="tender_value" type="measure" />
            </pivot>
        </field>
    </record>

    <record id="action_tender_analysis" model="ir.actions.act_window">
        <field name="name">Tender Analysis</field>
        <field name="res_model">tender.request</field>
        <field name="view_mode">pivot,graph</field>
        <field name="view_id" ref="view_tender_request_pivot" />
    </record>

    <menuitem id="menu_tender_reporting" name="Reporting" parent="menu_tender_root" sequence="99" />
    <menuitem id="menu_tender_analysis_report" name="Tender Analysis" parent="menu_tender_reporting"
        action="action_tender_analysis" sequence="1" />
</odoo>