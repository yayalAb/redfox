<odoo>
    <record id="view_tender_stage_tree" model="ir.ui.view">
        <field name="name">tender.stage.tree</field>
        <field name="model">tender.stage</field>
        <field name="arch" type="xml">
            <list string="Tender Stages" editable="bottom">
                <field name="sequence" widget="handle" />
                <field name="name" />
                <field name="is_won" />
                <field name="is_lost" />
                <field name="fold" />
            </list>
        </field>
    </record>

    <record id="action_tender_stage" model="ir.actions.act_window">
        <field name="name">Tender Stages</field>
        <field name="res_model">tender.stage</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_tender_stage" name="Tender Stages" parent="menu_tender_root"
        action="action_tender_stage" sequence="5" />
</odoo>