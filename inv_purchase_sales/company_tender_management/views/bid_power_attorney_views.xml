<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- list View -->
    <record id="view_bid_power_attorney_list" model="ir.ui.view">
        <field name="name">bid.power.attorney.list</field>
        <field name="model">bid.power.attorney</field>
        <field name="arch" type="xml">
            <list string="Power of Attorney">
                <field name="name"/>
                <field name="procuring_entity_id"/>
                <field name="bid_reference"/>
                <field name="representative_id"/>
                <field name="date_issue"/>
            </list>
        </field>
    </record>

    <record id="view_bid_power_attorney_form" model="ir.ui.view">
        <field name="name">bid.power.attorney.form</field>
        <field name="model">bid.power.attorney</field>
        <field name="arch" type="xml">
            <form string="Power of Attorney">
                <header>
                </header>
                <sheet>
                    <div class="oe_title">
                    <label for="name" string="Reference Number"/>
                    <h1><field name="name"/></h1>
                </div>
                    <group>
                        <group string="Bidder Info">
                            <field name="company_id" readonly="1"/>
                            <field name="date_issue"/>
                        </group>
                        <group string="Client Info">
                            <field name="procuring_entity_id" widget="res_partner_many2one" context="{'show_address': 1}"/>
                        </group>
                    </group>
                    
                    <group string="Authorization Details">
                        <field name="goods_description" placeholder="e.g. IT Equipment and Networking materials"/>
                        <field name="representative_id"/>
                        <field name="tender_description" placeholder="e.g. Supply and Installation of LAN"/>
                        <field name="bid_reference" placeholder="e.g. REF-2025-001"/>
                    </group>

                    <group string="Signatory (Official)">
                        <field name="official_id"/>
                        <field name="official_title"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_bid_power_attorney" model="ir.actions.act_window">
        <field name="name">Power of Attorney</field>
        <field name="res_model">bid.power.attorney</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_bid_power_attorney" name="Power of Attorney" parent="company_tender_management.menu_tender_root" action="action_bid_power_attorney"/>
</odoo>