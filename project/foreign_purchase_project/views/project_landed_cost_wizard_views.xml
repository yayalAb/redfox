<odoo>
    <record id="view_project_landed_cost_wizard_form" model="ir.ui.view">
        <field name="name">project.landed.cost.wizard.form</field>
        <field name="model">project.landed.cost.wizard</field>
        <field name="arch" type="xml">
            <form string="Add Payment">
                <group>
                    <field name="project_id" invisible="1" />
                    <field name="product_id" options="{'no_create': True}" />
                    <field name="amount" />
                </group>
                <footer>
                    <button name="action_create_landed_cost" type="object"
                        string="Add Payment" class="btn-primary" />
                    <button string="Cancel" class="btn-secondary" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
</odoo>