<odoo>
    <record id="view_project_stage_foreign_purchase_list" model="ir.ui.view">
        <field name="name">project.stage.foreign.purchase.list</field>
        <field name="model">project.project.stage</field>
        <field name="inherit_id" ref="project.project_project_stage_view_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="is_foreign_purchase" />
                <field name="is_bill" />
                <field name="accountable_user_ids" widget="many2many_tags_avatar"
                    options="{'no_create': True}" />
            </xpath>
        </field>
    </record>

    <record id="view_project_foreign_purchase_kanban_inherited" model="ir.ui.view">
        <field name="name">project.project.kanban.inherited</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.view_project_kanban" />
        <field name="arch" type="xml">
            <xpath expr="//footer//div[contains(@class, 'ms-auto')]" position="after">
                <field name="stage_is_bill" invisible="1" />
                <button name="action_open_landed_cost_wizard"
                    type="object"
                    class="btn btn-sm btn-primary me-2"
                    string="Create Payment"
                    invisible="not stage_is_bill">
                </button>
            </xpath>
        </field>
    </record>

    <record id="view_project_project_form_inherit_landed_cost" model="ir.ui.view">
        <field name="name">project.project.form.inherit.landed.cost</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project" />
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_open_landed_cost_wizard"
                    type="object"
                    string="Create Payment"
                    class="oe_highlight"
                    invisible="not stage_is_bill" />
            </xpath>
        </field>
    </record>
</odoo>